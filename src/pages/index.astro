---
import Base from '../layouts/Base.astro';

// FAQ Structured Data (Google FAQ Rich Snippet)
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Brauche ich ein Smartphone f\u00fcr FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. FragSMS funktioniert mit jedem Handy, das SMS senden kann \u2014 auch mit \u00e4lteren Feature Phones und Prepaid-Handys."
      }
    },
    {
      "@type": "Question",
      "name": "Brauche ich Internet oder WLAN f\u00fcr FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. FragSMS funktioniert komplett \u00fcber SMS im Mobilfunknetz. Kein WLAN, kein Datenplan und keine App n\u00f6tig."
      }
    },
    {
      "@type": "Question",
      "name": "Wie k\u00fcndige ich mein FragSMS Abo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sende einfach STOP per SMS oder nutze den \u201eJetzt k\u00fcndigen\u201c Button auf fragsms.de/upgrade. Die K\u00fcndigung ist sofort wirksam, ohne Wartezeit."
      }
    },
    {
      "@type": "Question",
      "name": "Sind meine Daten bei FragSMS sicher?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja. Alle Daten werden ausschlie\u00dflich auf EU-Servern gespeichert. Deine Telefonnummer wird per SHA-256 verschl\u00fcsselt und nie im Klartext gespeichert. FragSMS ist vollst\u00e4ndig DSGVO-konform."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Zahlungsmethoden unterst\u00fctzt FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kreditkarte, SEPA-Lastschrift, PayPal und Sofort\u00fcberweisung \u2014 die beliebtesten Zahlungsmethoden in Deutschland. Sichere Abwicklung \u00fcber Stripe."
      }
    },
    {
      "@type": "Question",
      "name": "Was kostet FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FragSMS bietet einen kostenlosen Tarif mit 20 Nachrichten pro Monat. Basic kostet 4,99 \u20ac/Monat (200 Nachrichten) und Pro kostet 9,99 \u20ac/Monat (unbegrenzt). Alle Preise sind Endpreise."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich ChatGPT per SMS nutzen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mit FragSMS kannst du einen KI-Assistenten per SMS nutzen \u2014 \u00e4hnlich wie ChatGPT, aber ohne App und ohne Internet. Einfach eine SMS senden und sofort eine KI-Antwort erhalten."
      }
    }
  ]
};

// Service Structured Data
const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "FragSMS",
  "description": "KI-Assistent per SMS in Deutschland. Stelle Fragen per SMS und erhalte sofort KI-Antworten. Kein Smartphone, kein Internet, kein Account n\u00f6tig.",
  "provider": {
    "@type": "Organization",
    "name": "FragSMS",
    "url": "https://fragsms.de"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Germany"
  },
  "serviceType": "KI-Assistent per SMS",
  "offers": [
    {
      "@type": "Offer",
      "name": "FragSMS Free",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "20 kostenlose KI-Nachrichten pro Monat per SMS"
    },
    {
      "@type": "Offer",
      "name": "FragSMS Basic",
      "price": "4.99",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "4.99",
        "priceCurrency": "EUR",
        "billingDuration": "P1M"
      },
      "description": "200 KI-Nachrichten pro Monat per SMS"
    },
    {
      "@type": "Offer",
      "name": "FragSMS Pro",
      "price": "9.99",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "9.99",
        "priceCurrency": "EUR",
        "billingDuration": "P1M"
      },
      "description": "Unbegrenzte KI-Nachrichten pro Monat per SMS"
    }
  ]
};

// BreadcrumbList for homepage
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "https://fragsms.de/"
    }
  ]
};
---

<Base
  title="FragSMS — KI-Assistent per SMS | ChatGPT per SMS in Deutschland"
  description="FragSMS ist dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Stelle Fragen per SMS und erhalte sofort Antworten. DSGVO-konform, EU-Daten. Ab 0 EUR kostenlos testen."
  keywords="KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, AI SMS ohne App, DSGVO KI Assistent, KI ohne Smartphone, KI ohne Internet, FragSMS, kuenstliche Intelligenz SMS, SMS AI Deutschland, KI Feature Phone"
  jsonLd={[faqJsonLd, serviceJsonLd, breadcrumbJsonLd]}
>

  <!-- Hero Section -->
  <section class="section" style="padding: 6rem 0 5rem; text-align: center; position: relative; overflow: hidden;">
    <!-- Subtle gradient background -->
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(255, 215, 0, 0.06) 0%, transparent 60%); pointer-events: none;"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div class="fade-in">
        <span class="badge badge-gold" style="margin-bottom: 1.5rem;">KI per SMS in Deutschland</span>
      </div>
      <h1 class="fade-in" style="font-size: 3.25rem; font-weight: 800; line-height: 1.15; margin-bottom: 1rem; letter-spacing: -0.03em; max-width: 700px; margin-left: auto; margin-right: auto;">
        KI-Assistent<br><span class="text-gradient">per SMS</span>
      </h1>
      <p class="fade-in" style="font-size: 1.15rem; color: var(--color-text-muted); margin-bottom: 2.5rem; max-width: 500px; margin-left: auto; margin-right: auto;">
        Wie ChatGPT &mdash; aber per SMS. Kein App, kein Internet, kein Login. <strong style="color: var(--color-text);">Frag einfach.</strong>
      </p>

      <!-- Phone number card -->
      <div class="fade-in card" style="display: inline-block; max-width: 420px; text-align: center; border-color: rgba(255, 215, 0, 0.2); background: linear-gradient(135deg, var(--color-surface), rgba(255, 215, 0, 0.03));">
        <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Sende eine SMS an</p>
        <p style="font-size: 2rem; font-weight: 800; color: var(--color-primary); letter-spacing: 2px; margin-bottom: 0.5rem;">
          +49 XXX XXXXXXX
        </p>
        <p style="font-size: 0.85rem; color: var(--color-text-muted);">
          20 kostenlose Nachrichten pro Monat &mdash; kein Abo n&ouml;tig
        </p>
      </div>

      <!-- German flag accent bar -->
      <div class="fade-in" style="display: flex; justify-content: center; gap: 0; margin-top: 2.5rem;">
        <div style="width: 40px; height: 4px; background: #000; border-radius: 2px 0 0 2px;"></div>
        <div style="width: 40px; height: 4px; background: #DD0000;"></div>
        <div style="width: 40px; height: 4px; background: #FFD700; border-radius: 0 2px 2px 0;"></div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" style="background: var(--color-bg-alt);" aria-labelledby="how-it-works">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="how-it-works">So funktioniert <span class="text-gradient">KI per SMS</span></h2>
        <p>In 3 einfachen Schritten zur KI-Antwort &mdash; ganz ohne Smartphone oder Internet.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 950px; margin: 0 auto;">

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid rgba(255,215,0,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">1</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">SMS senden</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;">
            Sende deine Frage per SMS an unsere deutsche +49 Nummer. Funktioniert mit jedem Handy &mdash; auch Feature Phones.
          </p>
        </article>

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid rgba(255,215,0,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">2</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">KI antwortet sofort</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;">
            Unsere k&uuml;nstliche Intelligenz versteht deine Frage und antwortet auf Deutsch &mdash; direkt per SMS in Sekunden.
          </p>
        </article>

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid rgba(255,215,0,0.2); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">3</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Fertig &mdash; so einfach</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;">
            Kein Download, kein Account, kein Internet n&ouml;tig. KI f&uuml;r alle &mdash; auch Senioren, Feature Phones und l&auml;ndliche Gebiete.
          </p>
        </article>

      </div>
    </div>
  </section>

  <!-- Features — Tabbed panels like KobiDev -->
  <section class="section" aria-labelledby="features-heading" style="overflow: hidden;">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="features-heading">Warum <span class="text-gradient">FragSMS</span>?</h2>
        <p>Datenschutz, EU-Datenstandort und Einfachheit &mdash; <strong style="color: var(--color-text);">Made in Germany</strong>.</p>
      </div>

      <!-- Feature tabs -->
      <div class="fade-in" style="max-width: 700px; margin: 0 auto;">
        <!-- Tab buttons -->
        <div id="feature-tabs" style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem;" role="tablist" aria-label="Feature-Tabs">
          <button class="feature-tab active" data-index="0" role="tab" aria-selected="true" aria-controls="feature-panel-0" style="padding: 0.6rem 1.25rem; border-radius: 8px; border: 1px solid var(--color-primary); background: var(--color-primary-glow); color: var(--color-primary); font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">EU-Daten</button>
          <button class="feature-tab" data-index="1" role="tab" aria-selected="false" aria-controls="feature-panel-1" style="padding: 0.6rem 1.25rem; border-radius: 8px; border: 1px solid var(--color-border); background: transparent; color: var(--color-text-muted); font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">Datenschutz</button>
          <button class="feature-tab" data-index="2" role="tab" aria-selected="false" aria-controls="feature-panel-2" style="padding: 0.6rem 1.25rem; border-radius: 8px; border: 1px solid var(--color-border); background: transparent; color: var(--color-text-muted); font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">Verschl&uuml;sselung</button>
          <button class="feature-tab" data-index="3" role="tab" aria-selected="false" aria-controls="feature-panel-3" style="padding: 0.6rem 1.25rem; border-radius: 8px; border: 1px solid var(--color-border); background: transparent; color: var(--color-text-muted); font-size: 0.85rem; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.2s;">Zahlung</button>
        </div>

        <!-- Tab panels -->
        <div id="feature-panel-0" class="feature-panel card" role="tabpanel" style="text-align: center; padding: 2.5rem;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">&#127466;&#127482;</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Daten bleiben in Europa &mdash; garantiert</h3>
          <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 450px; margin: 0 auto;">
            Alle deine Daten werden ausschlie&szlig;lich auf <strong style="color: var(--color-text);">EU-Servern</strong> gespeichert (Cloudflare D1, EU-Jurisdiction).
            Keine Daten&uuml;bertragung in die USA. Vollst&auml;ndig <strong style="color: var(--color-text);">DSGVO-konform</strong> &mdash; von Anfang an.
          </p>
          <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
            <span class="badge badge-gold">EU-Server</span>
            <span class="badge badge-gold">DSGVO</span>
            <span class="badge badge-gold">Verschl&uuml;sselt</span>
          </div>
        </div>

        <div id="feature-panel-1" class="feature-panel card" role="tabpanel" style="text-align: center; padding: 2.5rem; display: none;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">&#128274;</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">STOP senden = Alle Daten gel&ouml;scht</h3>
          <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 450px; margin: 0 auto;">
            Sende <strong style="color: var(--color-text);">STOP</strong> und alle deine Daten werden sofort entfernt. Kein Nachfragen, keine Wartezeit, keine versteckten Kopien.
            Deine <strong style="color: var(--color-text);">Privatsph&auml;re</strong> ist bei uns kein Feature &mdash; sie ist das Fundament.
          </p>
          <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
            <span class="badge badge-red">Sofort-L&ouml;schung</span>
            <span class="badge badge-red">Kein Tracking</span>
            <span class="badge badge-red">Kein Profiling</span>
          </div>
        </div>

        <div id="feature-panel-2" class="feature-panel card" role="tabpanel" style="text-align: center; padding: 2.5rem; display: none;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">&#128373;</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Deine Nummer bleibt geheim</h3>
          <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 450px; margin: 0 auto;">
            Wir speichern deine Telefonnummer <strong style="color: var(--color-text);">niemals im Klartext</strong>. Sie wird sofort verschl&uuml;sselt (SHA-256) &mdash;
            selbst wir k&ouml;nnen sie nicht zur&uuml;ckrechnen. Maximaler Datenschutz.
          </p>
          <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
            <span class="badge badge-gold">SHA-256 Hash</span>
            <span class="badge badge-gold">Kein Klartext</span>
            <span class="badge badge-gold">Nicht umkehrbar</span>
          </div>
        </div>

        <div id="feature-panel-3" class="feature-panel card" role="tabpanel" style="text-align: center; padding: 2.5rem; display: none;">
          <div style="font-size: 2.5rem; margin-bottom: 1rem;">&#128179;</div>
          <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">Zahle wie du willst</h3>
          <p style="color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.7; max-width: 450px; margin: 0 auto;">
            Kreditkarte, <strong style="color: var(--color-text);">SEPA-Lastschrift</strong>, <strong style="color: var(--color-text);">PayPal</strong>, Sofort&uuml;berweisung &mdash; die beliebtesten
            Zahlungsmethoden in Deutschland. Sicher &uuml;ber Stripe.
          </p>
          <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
            <span class="badge badge-muted">Kreditkarte</span>
            <span class="badge badge-muted">SEPA</span>
            <span class="badge badge-muted">PayPal</span>
            <span class="badge badge-muted">Sofort</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Feature tabs logic
    const tabs = document.querySelectorAll('.feature-tab');
    const panels = document.querySelectorAll('.feature-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const idx = parseInt(tab.dataset.index);

        // Update tabs
        tabs.forEach((t, i) => {
          const isActive = i === idx;
          t.classList.toggle('active', isActive);
          t.setAttribute('aria-selected', isActive ? 'true' : 'false');
          t.style.borderColor = isActive ? 'var(--color-primary)' : 'var(--color-border)';
          t.style.background = isActive ? 'var(--color-primary-glow)' : 'transparent';
          t.style.color = isActive ? 'var(--color-primary)' : 'var(--color-text-muted)';
        });

        // Update panels
        panels.forEach((p, i) => {
          p.style.display = i === idx ? 'block' : 'none';
        });
      });
    });
  </script>

  <!-- Pricing -->
  <section class="section" style="background: var(--color-bg-alt);" aria-labelledby="pricing-heading">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="pricing-heading"><span class="text-gradient">FragSMS</span> Preise</h2>
        <p>Kostenlos starten. Jederzeit upgraden. Jederzeit k&uuml;ndbar.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; max-width: 850px; margin: 0 auto;">

        <!-- Free -->
        <article class="card fade-in" style="text-align: center;">
          <h3 style="font-size: 1rem; margin-bottom: 0.75rem; color: var(--color-text-muted);">Free</h3>
          <p style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">&euro;0</p>
          <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">pro Monat</p>
          <ul style="list-style: none; text-align: left; font-size: 0.9rem; color: var(--color-text-muted);">
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> 20 Nachrichten / Monat</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> KI-Antworten auf Deutsch</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Kein Account n&ouml;tig</li>
          </ul>
        </article>

        <!-- Basic — highlighted -->
        <article class="card fade-in" style="text-align: center; border-color: var(--color-primary); position: relative; box-shadow: 0 0 30px rgba(255, 215, 0, 0.08);">
          <div style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: #0a0a0a; padding: 0.25rem 1.25rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.025em;">
            Beliebt
          </div>
          <h3 style="font-size: 1rem; margin-bottom: 0.75rem; color: var(--color-primary);">Basic</h3>
          <p style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">&euro;4,99</p>
          <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">pro Monat</p>
          <ul style="list-style: none; text-align: left; font-size: 0.9rem; color: var(--color-text-muted);">
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> 200 Nachrichten / Monat</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Gespr&auml;chsverlauf</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Jederzeit k&uuml;ndbar</li>
          </ul>
          <a href="/upgrade" class="btn-primary" style="display: block; margin-top: 1.5rem; text-align: center;">
            Jetzt upgraden
          </a>
        </article>

        <!-- Pro -->
        <article class="card fade-in" style="text-align: center;">
          <h3 style="font-size: 1rem; margin-bottom: 0.75rem; color: var(--color-text-muted);">Pro</h3>
          <p style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.25rem;">&euro;9,99</p>
          <p style="color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">pro Monat</p>
          <ul style="list-style: none; text-align: left; font-size: 0.9rem; color: var(--color-text-muted);">
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Unbegrenzte Nachrichten</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Gespr&auml;chsverlauf</li>
            <li style="padding: 0.4rem 0; display: flex; align-items: center; gap: 0.5rem;"><span style="color: var(--color-primary);">&#10003;</span> Priorit&auml;ts-Antworten</li>
          </ul>
          <a href="/upgrade" class="btn-secondary" style="display: block; margin-top: 1.5rem; text-align: center;">
            Jetzt upgraden
          </a>
        </article>

      </div>
      <p class="fade-in" style="text-align: center; font-size: 0.8rem; color: #666; margin-top: 2rem;">
        Alle Preise sind Endpreise. Gem&auml;&szlig; &sect; 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.
      </p>
    </div>
  </section>

  <!-- SEO long-form content section -->
  <section class="section" aria-labelledby="about-heading">
    <div class="container" style="max-width: 700px;">
