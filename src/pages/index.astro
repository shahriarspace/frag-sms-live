  <script>
    // Phone SMS carousel
    (function() {
      var conversations = document.querySelectorAll('.sms-conversation');
      var dots = document.querySelectorAll('.dot');
      var currentIdx = 0;
      var autoTimer;
      function showConv(idx) {
        conversations.forEach(function(c) { c.classList.remove('active'); });
        dots.forEach(function(d) { d.classList.remove('active'); });
        conversations[idx].classList.add('active');
        dots[idx].classList.add('active');
        currentIdx = idx;
      }
      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          showConv(parseInt(dot.getAttribute('data-dot')));
          clearInterval(autoTimer);
          autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
        });
      });
      autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
    })();

    // START button — open SMS app
    document.getElementById('start-btn')?.addEventListener('click', function() {
      var val = document.getElementById('phone-input')?.value?.trim();
      alert('Bitte sende START per SMS an unsere +49 Nummer. (Nummer wird bald bekanntgegeben)');
    });
  </script>

