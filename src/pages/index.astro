  <script>
    // Phone SMS carousel — Switchback 1
    (function() {
      var screen = document.getElementById('sms-screen');
      if (!screen) return;
      var conversations = screen.querySelectorAll('.sms-conversation');
      var dotsWrap = screen.nextElementSibling;
      var dots = dotsWrap ? dotsWrap.querySelectorAll('.dot') : [];
      var currentIdx = 0;
      var autoTimer;
      function showConv(idx) {
        conversations.forEach(function(c) { c.classList.remove('active'); });
        dots.forEach(function(d) { d.classList.remove('active'); });
        conversations[idx].classList.add('active');
        dots[idx].classList.add('active');
        currentIdx = idx;
      }
      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          showConv(parseInt(dot.getAttribute('data-dot')));
          clearInterval(autoTimer);
          autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
        });
      });
      autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
    })();

    // Web signup — phone validation + POST to Worker
    var turnstileToken1 = '';
