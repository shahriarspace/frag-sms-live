    /* ── Privacy flow section — migrated to Tailwind ── */
    /* Kept: flow-diagram layout, arrows, animations, responsive */

    /* Diagram container — needed for responsive override */
    .flow-diagram {
      display: flex;
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    /* Horizontal arrows between columns — needed for responsive direction change */
    .flow-h-arrow {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      width: 36px;
      min-width: 24px;
      position: relative;
    }
    .flow-arrow-line {
      flex: 1;
      height: 2px;
      background: var(--color-primary);
      background-image: repeating-linear-gradient(90deg, var(--color-primary) 0 4px, transparent 4px 7px);
    }
    .flow-arrow-head {
      width: 0;
      height: 0;
      border-top: 5px solid transparent;
      border-bottom: 5px solid transparent;
      border-left: 7px solid var(--color-primary);
      flex-shrink: 0;
    }

    /* ── Sliding animation for flow diagram ── */
    @keyframes flowSlideIn {
      from {
        opacity: 0;
        transform: translateX(-32px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
    @keyframes flowSlideUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Chained fade-in (triggered by JS after first diagram finishes) */
    .fade-in-chain {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .fade-in-chain.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .flow-diagram > .flow-col,
    .flow-diagram > .flow-h-arrow {
      opacity: 0;
    }
    .flow-diagram.flow-visible > .flow-col,
    .flow-diagram.flow-visible > .flow-h-arrow {
      animation: flowSlideIn 0.5s ease forwards;
    }
    .flow-diagram.flow-visible > :nth-child(1) { animation-delay: 0ms; }
    .flow-diagram.flow-visible > :nth-child(2) { animation-delay: 100ms; }
    .flow-diagram.flow-visible > :nth-child(3) { animation-delay: 200ms; }
    .flow-diagram.flow-visible > :nth-child(4) { animation-delay: 300ms; }
    .flow-diagram.flow-visible > :nth-child(5) { animation-delay: 400ms; }
    .flow-diagram.flow-visible > :nth-child(6) { animation-delay: 500ms; }
    .flow-diagram.flow-visible > :nth-child(7) { animation-delay: 600ms; }
    .flow-diagram.flow-visible > :nth-child(8) { animation-delay: 700ms; }
    .flow-diagram.flow-visible > :nth-child(9) { animation-delay: 800ms; }

    /* ── SMS vs App/Web comparison — migrated to Tailwind ── */
    /* Kept: animation triggers only */
    .flow-compare {
      display: flex;
      align-items: stretch;
      gap: 0;
      width: 100%;
      max-width: 820px;
      margin: 0 auto;
    }

    /* Sliding animation for comparison cards */
    .flow-compare > .cmp-card,
    .flow-compare > .cmp-vs {
      opacity: 0;
    }
    .flow-compare.flow-visible > .cmp-card:first-child {
      animation: flowSlideIn 0.5s ease forwards;
      animation-delay: 0ms;
    }
    .flow-compare.flow-visible > .cmp-vs {
      animation: flowSlideUp 0.4s ease forwards;
      animation-delay: 200ms;
    }
    .flow-compare.flow-visible > .cmp-card:last-child {
      animation: flowSlideIn 0.5s ease forwards;
      animation-delay: 400ms;
    }

    .sms-privacy-warn {
      background: rgba(239,68,68,0.1) !important;
      border-color: rgba(239,68,68,0.3) !important;
      color: var(--color-text) !important;
    }

    /* ── Pricing ─────────────────────────────────── */
    /* pg-alt dot-grid pseudo-element — must stay in CSS */
    .pg-alt::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, rgba(16,185,129,0.04) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
    }

    /* ── Pricing featured card (pseudo-elements kept) ── */
    .pricing-card--featured::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 22px;
      background: linear-gradient(135deg, #10b981, #34d399, #059669, #10b981);
      background-size: 300% 300%;
      z-index: -1;
      animation: gradientShift 4s ease infinite;
    }
    .pricing-card--featured::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 20px;
      background: var(--color-surface);
      z-index: -1;
    }
    .pricing-card--featured:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 48px rgba(16,185,129,0.2);
    }

    /* ── FAQ marker rules (kept) ── */
    .faq-item summary::marker { display: none; }
    .faq-item summary::-webkit-details-marker { display: none; }

    /* ── Responsive ──────────────────────────────── */
    @media (max-width: 800px) {
      .flow-diagram {
        flex-direction: column;
        align-items: center;
        gap: 0;
      }
      .flow-col {
        width: 100%;
        max-width: 340px;
      }
      .flow-col--split {
        width: 100%;
        max-width: 340px;
        flex-direction: row;
      }
      .flow-h-arrow {
        width: auto;
