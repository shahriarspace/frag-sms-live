---
import Base from '../layouts/Base.astro';

// FAQ Structured Data (Google FAQ Rich Snippet)
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Brauche ich ein Smartphone f\u00fcr FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. FragSMS funktioniert mit jedem Handy, das SMS senden kann \u2014 auch mit \u00e4lteren Feature Phones und Prepaid-Handys."
      }
    },
    {
      "@type": "Question",
      "name": "Brauche ich Internet oder WLAN f\u00fcr FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. FragSMS funktioniert komplett \u00fcber SMS im Mobilfunknetz. Kein WLAN, kein Datenplan und keine App n\u00f6tig."
      }
    },
    {
      "@type": "Question",
      "name": "Wie k\u00fcndige ich mein FragSMS Abo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sende einfach STOP per SMS oder nutze den \u201eJetzt k\u00fcndigen\u201c Button auf fragsms.de/upgrade. Die K\u00fcndigung ist sofort wirksam, ohne Wartezeit."
      }
    },
    {
      "@type": "Question",
      "name": "Sind meine Daten bei FragSMS sicher?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja. Alle Daten werden ausschlie\u00dflich auf EU-Servern gespeichert. Deine Telefonnummer wird per SHA-256 verschl\u00fcsselt und nie im Klartext gespeichert. FragSMS ist vollst\u00e4ndig DSGVO-konform."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Zahlungsmethoden unterst\u00fctzt FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kreditkarte, SEPA-Lastschrift, PayPal und Sofort\u00fcberweisung \u2014 die beliebtesten Zahlungsmethoden in Deutschland. Sichere Abwicklung \u00fcber Stripe."
      }
    },
    {
      "@type": "Question",
      "name": "Was kostet FragSMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FragSMS bietet einen kostenlosen Tarif mit 10 Nachrichten pro Monat. Starter kostet 2,99 \u20ac/Monat (30 Nachrichten), Basic kostet 7,99 \u20ac/Monat (150 Nachrichten) und Pro kostet 19,99 \u20ac/Monat (500 Nachrichten). Alle Preise sind Endpreise."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich ChatGPT per SMS nutzen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mit FragSMS kannst du einen KI-Assistenten per SMS nutzen \u2014 \u00e4hnlich wie ChatGPT, aber ohne App und ohne Internet. Einfach eine SMS senden und sofort eine KI-Antwort erhalten."
      }
    }
  ]
};

// Service Structured Data
const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "FragSMS",
  "description": "KI-Assistent per SMS in Deutschland. Stelle Fragen per SMS und erhalte sofort KI-Antworten. Kein Smartphone, kein Internet, kein Account n\u00f6tig.",
  "provider": {
    "@type": "Organization",
    "name": "FragSMS",
    "url": "https://fragsms.de"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Germany"
  },
  "serviceType": "KI-Assistent per SMS",
  "offers": [
    {
      "@type": "Offer",
      "name": "FragSMS Free",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "10 kostenlose KI-Nachrichten pro Monat per SMS (max. 2 pro Tag)"
    },
    {
      "@type": "Offer",
      "name": "FragSMS Starter",
      "price": "2.99",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "2.99",
        "priceCurrency": "EUR",
        "billingDuration": "P1M"
      },
      "description": "30 KI-Nachrichten pro Monat per SMS (max. 3 pro Tag)"
    },
    {
      "@type": "Offer",
      "name": "FragSMS Basic",
      "price": "7.99",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "7.99",
        "priceCurrency": "EUR",
        "billingDuration": "P1M"
      },
      "description": "150 KI-Nachrichten pro Monat per SMS (max. 8 pro Tag)"
    },
    {
      "@type": "Offer",
      "name": "FragSMS Pro",
      "price": "19.99",
      "priceCurrency": "EUR",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "19.99",
        "priceCurrency": "EUR",
        "billingDuration": "P1M"
      },
      "description": "500 KI-Nachrichten pro Monat per SMS (max. 20 pro Tag)"
    }
  ]
};

// BreadcrumbList for homepage
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "https://fragsms.de/"
    }
  ]
};
---

<Base
  title="FragSMS — KI-Assistent per SMS | ChatGPT per SMS in Deutschland"
  description="FragSMS ist dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Stelle Fragen per SMS und erhalte sofort Antworten. DSGVO-konform, EU-Daten. Ab 0 EUR kostenlos testen."
  keywords="KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, AI SMS ohne App, DSGVO KI Assistent, KI ohne Smartphone, KI ohne Internet, FragSMS, kuenstliche Intelligenz SMS, SMS AI Deutschland, KI Feature Phone"
  jsonLd={[faqJsonLd, serviceJsonLd, breadcrumbJsonLd]}
>

  <!-- Hero Section with Phone Mockup -->
  <section class="section" style="padding: 5rem 0 4rem; position: relative; overflow: hidden;">
    <!-- Subtle emerald gradient background -->
    <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(16, 185, 129, 0.07) 0%, transparent 60%); pointer-events: none;"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; max-width: 1000px; margin: 0 auto;">

        <!-- Left: Text content -->
        <div>
          <div class="fade-in">
            <span class="badge badge-primary" style="margin-bottom: 1.5rem;" data-i18n="hero_badge">KI per SMS in Deutschland</span>
          </div>
          <h1 class="fade-in" style="font-size: 3rem; font-weight: 800; line-height: 1.15; margin-bottom: 1rem; letter-spacing: -0.03em;">
            <span data-i18n="hero_title_1">KI-Assistent</span><br><span class="text-gradient" data-i18n="hero_title_2">per SMS</span>
          </h1>
          <p class="fade-in" style="font-size: 1.1rem; color: var(--color-text-muted); margin-bottom: 2rem; max-width: 420px;">
            <span data-i18n="hero_subtitle">Wie ChatGPT &mdash; aber per SMS. Kein App, kein Internet, kein Login.</span> <strong style="color: var(--color-text);" data-i18n="hero_cta_text">Frag einfach.</strong>
          </p>

          <!-- Phone number card -->
          <div class="fade-in card" style="max-width: 380px; text-align: center; border-color: var(--color-primary-border); background: linear-gradient(135deg, var(--color-surface), rgba(16, 185, 129, 0.03));">
            <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;" data-i18n="hero_send_sms">Sende eine SMS an</p>
            <p style="font-size: 1.75rem; font-weight: 800; color: var(--color-primary); letter-spacing: 2px; margin-bottom: 0.4rem;">
              +49 XXX XXXXXXX
            </p>
            <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 1rem;" data-i18n="hero_free_msgs">10 kostenlose Nachrichten pro Monat &mdash; kein Abo n&ouml;tig</p>

            <!-- QR Code to save contact -->
            <div class="qr-section">
              <div class="qr-divider"></div>
              <div id="qr-code" class="qr-container" title="QR-Code scannen um FragSMS als Kontakt zu speichern"></div>
              <p class="qr-caption" data-i18n="hero_qr_caption">QR-Code scannen &mdash; Nummer als Kontakt speichern</p>
            </div>
          </div>

          <!-- CTA Button -->
          <div class="fade-in" style="margin-top: 1.5rem;">
            <a href="#pricing-heading" class="btn-primary" style="font-size: 1rem; padding: 0.85rem 2.25rem;" data-i18n="hero_cta_btn">Kostenlos starten &rarr;</a>
            <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.6rem;" data-i18n="hero_cta_sub">Kein Abo, kein Risiko, keine Kreditkarte</p>
          </div>

          <!-- German flag accent bar -->
          <div class="fade-in" style="display: flex; gap: 0; margin-top: 2rem;">
            <div style="width: 40px; height: 4px; background: #000; border-radius: 2px 0 0 2px;"></div>
            <div style="width: 40px; height: 4px; background: #DD0000;"></div>
            <div style="width: 40px; height: 4px; background: #FFD700; border-radius: 0 2px 2px 0;"></div>
          </div>
        </div>

        <!-- Right: Phone Mockup with SMS carousel -->
        <div class="fade-in" style="display: flex; justify-content: center;">
          <div class="phone-mockup">
            <!-- Phone frame -->
            <div class="phone-notch"></div>
            <div class="phone-header">
              <div style="font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">SMS</div>
              <div style="font-size: 1rem; font-weight: 700; color: var(--color-text);">FragSMS</div>
              <div style="font-size: 0.7rem; color: var(--color-text-muted);">+49 XXX</div>
            </div>

            <!-- SMS conversation area -->
            <div class="phone-screen" id="sms-screen">
              <!-- Conversation 1: Recipe (visible by default) -->
              <div class="sms-conversation active" data-conv="0">
                <div class="sms-label" data-i18n="sms_label_0">Kochen &amp; Rezepte</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_0">Was kann ich mit Kartoffeln, Zwiebeln und Eiern kochen? Schnelles Abendessen!</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_0">Spanische Tortilla! 4 Kartoffeln schaelen und duenn schneiden. In Oel 15 Min braten. 1 Zwiebel dazu, 5 Min. 6 Eier verquirlen, salzen, ueber die Kartoffeln giessen. Bei kleiner Hitze 8 Min stocken lassen, dann wenden. Fertig in 30 Min!</div>
              </div>

              <!-- Conversation 2: Translation help -->
              <div class="sms-conversation" data-conv="1">
                <div class="sms-label" data-i18n="sms_label_1">Alltagshilfe</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_1">Wie sage ich auf Englisch: Ich moechte einen Termin beim Arzt verschieben?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_1">I would like to reschedule my doctor's appointment. Oder hoeflicher: Could I please reschedule my appointment? Wenn du anrufst: Hi, I'm calling to reschedule my appointment on [Datum].</div>
              </div>

              <!-- Conversation 3: Factual question without internet -->
              <div class="sms-conversation" data-conv="2">
                <div class="sms-label" data-i18n="sms_label_2">Wissen &amp; Fakten</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_2">Wie hoch ist die Zugspitze und kann man da im Winter wandern?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_2">Die Zugspitze ist 2.962 m hoch, Deutschlands hoechster Berg. Im Winter: Wandern nur auf geraeumt Wegen moeglich (z.B. Partnachklamm). Gipfel per Seilbahn erreichbar. Skigebiet an der Zugspitze hat ca. Nov-Mai Saison.</div>
              </div>

              <!-- Conversation 4: Seniors / practical help -->
              <div class="sms-conversation" data-conv="3">
                <div class="sms-label" data-i18n="sms_label_3">Senioren-Hilfe</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_3">Mein Enkel hat Geburtstag, er wird 8. Was schenkt man Kindern in dem Alter?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_3">Tolle Ideen fuer 8-Jaehrige: 1) LEGO-Set (ab 20 EUR) 2) Kinderbuch-Reihe (Die drei ???-Kids) 3) Experiment-Baukasten 4) Eintrittskarten fuer Zoo/Freizeitpark 5) Ferngesteuertes Auto. Budget-Tipp: Buch + Suessigkeiten = immer ein Hit!</div>
              </div>

              <!-- Conversation 5: No internet scenario -->
              <div class="sms-conversation" data-conv="4">
                <div class="sms-label" data-i18n="sms_label_4">Ohne Internet</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_4">Bin auf dem Land, kein Internet. Wann faehrt der naechste Zug von Aachen nach Koeln?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_4">RE1 Aachen-Koeln faehrt alle 30 Min. Fahrzeit ca. 50 Min. Letzter Zug ca. 23:30. Tipp: Am Bahnhof haengen auch Papier-Fahrplaene. Fuer genaue Zeiten ruf die DB-Hotline an: 030 2970.</div>
              </div>
            </div>

            <!-- Carousel dots -->
            <div class="phone-dots">
              <button class="dot active" data-dot="0" aria-label="Beispiel 1"></button>
              <button class="dot" data-dot="1" aria-label="Beispiel 2"></button>
              <button class="dot" data-dot="2" aria-label="Beispiel 3"></button>
              <button class="dot" data-dot="3" aria-label="Beispiel 4"></button>
              <button class="dot" data-dot="4" aria-label="Beispiel 5"></button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section style="padding: 2rem 0; border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <div class="trust-strip fade-in">
        <div class="trust-item">
          <div class="trust-icon">&#128274;</div>
          <div>
            <div class="trust-label" data-i18n="trust_dsgvo">DSGVO-konform</div>
            <div class="trust-sub" data-i18n="trust_dsgvo_sub">100% EU-Datenschutz</div>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#127466;&#127482;</div>
          <div>
            <div class="trust-label" data-i18n="trust_eu">EU-Server</div>
            <div class="trust-sub" data-i18n="trust_eu_sub">Keine US-Daten</div>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#10003;</div>
          <div>
            <div class="trust-label" data-i18n="trust_cancel">Jederzeit k&uuml;ndbar</div>
            <div class="trust-sub" data-i18n="trust_cancel_sub">Keine Mindestlaufzeit</div>
          </div>
        </div>
        <div class="trust-item">
          <div class="trust-icon">&#128176;</div>
          <div>
            <div class="trust-label" data-i18n="trust_price">Keine versteckten Kosten</div>
            <div class="trust-sub" data-i18n="trust_price_sub">Alle Preise sind Endpreise</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- German flag tricolor divider -->
  <div class="tricolor-divider"><div></div><div></div><div></div></div>
  <section class="section" style="background: var(--color-bg-alt);" aria-labelledby="how-it-works">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="how-it-works"><span data-i18n="how_title_1">So funktioniert</span> <span class="text-gradient" data-i18n="how_title_2">KI per SMS</span></h2>
        <p data-i18n="how_subtitle">In 3 einfachen Schritten zur KI-Antwort &mdash; ganz ohne Smartphone oder Internet.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 950px; margin: 0 auto;">

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid var(--color-primary-border); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">1</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;" data-i18n="step1_title">START senden</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;" data-i18n="step1_desc">
            Sende <strong style="color: var(--color-primary);">START</strong> per SMS an unsere +49 Nummer. Du erh&auml;ltst sofort eine Best&auml;tigung &mdash; fertig, du bist dabei.
          </p>
        </article>

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid var(--color-primary-border); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">2</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;" data-i18n="step2_title">Frag was du willst</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;" data-i18n="step2_desc">
            Schreibe deine Frage als SMS. Unsere KI antwortet auf Deutsch &mdash; direkt per SMS in Sekunden. Rezepte, &Uuml;bersetzungen, Fakten, Reisetipps &mdash; alles m&ouml;glich.
          </p>
        </article>

        <article class="card fade-in" style="text-align: center;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--color-primary-glow); border: 1px solid var(--color-primary-border); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.25rem; font-weight: 800; color: var(--color-primary);">3</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;" data-i18n="step3_title">STOP = Alles gel&ouml;scht</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem;" data-i18n="step3_desc">
            Willst du aufh&ouml;ren? Sende <strong style="color: var(--color-error);">STOP</strong> &mdash; sofort abgemeldet, dein gesamter Chatverlauf wird unwiderruflich gel&ouml;scht. Keine Frist, keine Datenr&uuml;ckst&auml;nde.
          </p>
        </article>

      </div>

      <!-- START/STOP visual explainer -->
      <div class="fade-in" style="max-width: 650px; margin: 3rem auto 0;">
        <div class="start-stop-visual">
          <div class="ss-card ss-start">
            <div class="ss-cmd">START</div>
            <div class="ss-arrow">&#8594;</div>
            <div class="ss-result">
              <span class="ss-label" data-i18n="ss_start_label">Anmeldung</span>
              <span class="ss-detail" data-i18n="ss_start_detail">Sofort loschatten, 10 gratis Nachrichten</span>
            </div>
          </div>
          <div class="ss-divider">
            <div class="ss-line"></div>
            <span class="ss-between" data-i18n="ss_between">Du chattest mit KI per SMS</span>
            <div class="ss-line"></div>
          </div>
          <div class="ss-card ss-stop">
            <div class="ss-cmd ss-cmd-stop">STOP</div>
            <div class="ss-arrow">&#8594;</div>
            <div class="ss-result">
              <span class="ss-label" data-i18n="ss_stop_label">Sofort abgemeldet</span>
              <span class="ss-detail" data-i18n="ss_stop_detail">Alle Daten &amp; Chatverlauf unwiderruflich gel&ouml;scht</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- German flag tricolor divider -->
  <div class="tricolor-divider"><div></div><div></div><div></div></div>

  <!-- Social Proof / Testimonials -->
  <section class="section" aria-labelledby="testimonials-heading">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="testimonials-heading"><span data-i18n="social_title_1">Das sagen unsere</span> <span class="text-gradient" data-i18n="social_title_2">Nutzer</span></h2>
        <p data-i18n="social_subtitle">Echte Menschen, echte Erfahrungen mit FragSMS.</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; max-width: 950px; margin: 0 auto;">

        <article class="card fade-in" style="position: relative;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-primary-glow); border: 1px solid var(--color-primary-border); display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--color-primary); font-size: 0.9rem;">HM</div>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;">Helga M.</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted);" data-i18n="review1_role">Rentnerin, 72 &mdash; M&uuml;nchen</div>
            </div>
          </div>
          <div style="color: var(--color-primary); font-size: 0.85rem; margin-bottom: 0.5rem;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.7; font-style: italic;" data-i18n="review1_text">&bdquo;Endlich kann ich auch KI nutzen! Mein Enkel hat mir gezeigt, wie ich eine SMS schreibe &mdash; mehr brauche ich nicht. Ich frage nach Rezepten und Gesundheitstipps. Wunderbar einfach!&ldquo;</p>
        </article>

        <article class="card fade-in" style="position: relative;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-primary-glow); border: 1px solid var(--color-primary-border); display: flex; align-items: center; justify-content: center; font-weight: 700; color: var(--color-primary); font-size: 0.9rem;">TK</div>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;">Thomas K.</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted);" data-i18n="review2_role">Handwerker, 45 &mdash; Eifel</div>
            </div>
          </div>
