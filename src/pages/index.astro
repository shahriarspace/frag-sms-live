---
import Base from '../layouts/Base.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Brauche ich ein Smartphone für FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. FragSMS funktioniert mit jedem Handy, das SMS senden kann — auch mit älteren Feature Phones und Prepaid-Handys." } },
    { "@type": "Question", "name": "Brauche ich Internet oder WLAN für FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. FragSMS funktioniert komplett über SMS im Mobilfunknetz. Kein WLAN, kein Datenplan und keine App nötig." } },
    { "@type": "Question", "name": "Kann ich ChatGPT per SMS nutzen?", "acceptedAnswer": { "@type": "Answer", "text": "Mit FragSMS kannst du einen KI-Assistenten per SMS nutzen - ähnlich wie ChatGPT, aber ohne App und ohne Internet. Einfach eine SMS senden und sofort eine KI-Antwort erhalten." } },
    { "@type": "Question", "name": "Wie kündige ich mein FragSMS Abo?", "acceptedAnswer": { "@type": "Answer", "text": "Sende einfach STOP per SMS oder nutze den 'Jetzt kündigen' Button auf fragsms.de/upgrade. Die Kündigung ist sofort wirksam, ohne Wartezeit." } },
    { "@type": "Question", "name": "Sind meine Daten bei FragSMS sicher?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. Alle Daten werden ausschließlich auf EU-Servern gespeichert. Deine Telefonnummer wird per SHA-256 verschlüsselt und nie im Klartext gespeichert. FragSMS ist vollständig DSGVO-konform." } },
    { "@type": "Question", "name": "Was kostet FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "FragSMS bietet einen kostenlosen Tarif mit 10 Nachrichten pro Monat. Starter kostet 2,99 €/Monat (30 Nachrichten), Basic kostet 7,99 €/Monat (150 Nachrichten) und Pro kostet 19,99 €/Monat (500 Nachrichten)." } }
  ]
};

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "FragSMS",
  "description": "KI-Assistent per SMS in Deutschland. Stelle Fragen per SMS und erhalte sofort KI-Antworten.",
  "provider": { "@type": "Organization", "name": "FragSMS", "url": "https://fragsms.de" },
  "areaServed": { "@type": "Country", "name": "Germany" },
  "serviceType": "KI-Assistent per SMS",
  "offers": [
    { "@type": "Offer", "name": "FragSMS Free", "price": "0", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "FragSMS Starter", "price": "2.99", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "FragSMS Basic", "price": "7.99", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "FragSMS Pro", "price": "19.99", "priceCurrency": "EUR" }
  ]
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://fragsms.de/" }]
};
---

<Base
  title="FragSMS — KI-Assistent per SMS | ChatGPT per SMS in Deutschland"
  description="FragSMS ist dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Stelle Fragen per SMS und erhalte sofort Antworten. DSGVO-konform, EU-Daten. Ab 0 EUR kostenlos testen."
  keywords="KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, AI SMS ohne App, DSGVO KI Assistent, KI ohne Smartphone, KI ohne Internet, FragSMS, kuenstliche Intelligenz SMS, SMS AI Deutschland"
  jsonLd={[faqJsonLd, serviceJsonLd, breadcrumbJsonLd]}
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="hero-section">
    <div class="hero-glow"></div>
    <div class="container hero-inner">

      <div class="fade-in">
        <span class="pill" data-i18n="hero_badge">KI per SMS in Deutschland</span>
      </div>

      <h1 class="hero-title fade-in">
        <span data-i18n="hero_title_1">Dein KI-Assistent.</span><br>
        <span class="text-gradient" data-i18n="hero_title_2">Per SMS.</span>
      </h1>

      <p class="hero-sub fade-in" data-i18n="hero_subtitle">
        Wie ChatGPT &mdash; aber per SMS. Kein App, kein Internet, kein Login. Einfach fragen.
      </p>

      <!-- Big phone number input bar -->
      <div class="hero-input-wrap fade-in">
        <div class="hero-input-inner" id="phone-wrap">
          <svg class="hero-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
          </svg>
          <input
            id="phone-input"
            type="tel"
            class="hero-input"
            placeholder="+49 XXX XXXXXXX"
            aria-label="Deine Handynummer"
            data-i18n-placeholder="hero_input_placeholder"
          />
          <!-- Honeypot: hidden from humans, bots fill it -->
          <input type="text" name="website_url" id="hp-field" autocomplete="off" tabindex="-1" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
          <button class="hero-btn" id="start-btn" disabled aria-label="Kostenlos starten">
            <span data-i18n="hero_btn">Kostenlos starten</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
        </div>
        <p class="hero-input-error" id="phone-error" aria-live="polite"></p>

        <!-- Consent checkboxes -->
        <div class="signup-checks" id="signup-checks">
          <label class="signup-check">
            <input type="checkbox" id="privacy-check" />
            <span data-i18n="signup_privacy">Ich stimme den <a href="/frag-sms-live/nutzungsbedingungen/" target="_blank">Nutzungsbedingungen</a> und der <a href="/frag-sms-live/datenschutz/" target="_blank">Datenschutzerkl&auml;rung</a> zu.</span>
          </label>
          <label class="signup-check">
            <input type="checkbox" id="age-check" />
            <span data-i18n="signup_age">Ich bin mindestens 16 Jahre alt.</span>
          </label>
        </div>

        <!-- Turnstile widget -->
        <div id="turnstile-container" class="cf-turnstile" data-sitekey="YOUR_TURNSTILE_SITE_KEY" data-callback="onTurnstileSuccess" data-theme="dark"></div>

        <!-- Success state (hidden by default) -->
        <div class="signup-success" id="signup-success" style="display:none;">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2.5" width="28" height="28" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <p data-i18n="signup_success"><strong>SMS gesendet!</strong> Pr&uuml;fe dein Handy und antworte mit <strong>JA</strong> um dein Konto zu aktivieren.</p>
        </div>

        <p class="hero-input-sub fade-in" id="hero-input-sub" data-i18n="hero_input_sub">
          10 kostenlose Nachrichten pro Monat &mdash; kein Abo, kein Risiko
        </p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       STATS BAR
  ════════════════════════════════════════════════ -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item fade-in">
        <span class="stat-num">100%</span>
        <span class="stat-label" data-i18n="stat1">DSGVO-konform</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in">
        <span class="stat-num">EU</span>
        <span class="stat-label" data-i18n="stat2">Server &amp; Datenschutz</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in">
        <span class="stat-num">&euro;0</span>
        <span class="stat-label" data-i18n="stat3">Kostenlos starten</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item fade-in">
        <span class="stat-num">&lt;5s</span>
        <span class="stat-label" data-i18n="stat4">Antwortzeit</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SWITCHBACK 1 — SMS Demo (phone mockup left)
  ════════════════════════════════════════════════ -->
  <section class="sb-section">
    <div class="container sb-grid">

      <!-- Left: Phone mockup -->
      <div class="sb-media fade-in">
        <div class="phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-header">
            <div class="phone-header-label">SMS</div>
            <div class="phone-header-title">FragSMS</div>
            <div class="phone-header-num">+49 XXX</div>
          </div>
          <div class="phone-screen" id="sms-screen">
            <div class="sms-conversation active" data-conv="0">
              <div class="sms-label" data-i18n="sms_label_0">Kochen &amp; Rezepte</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_0">Was kann ich mit Kartoffeln, Zwiebeln und Eiern kochen?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_0">Spanische Tortilla! Kartoffeln d&uuml;nn schneiden, in &Ouml;l 15 Min braten. Zwiebel dazu. 6 Eier verquirlen, salzen, dazugeben. Kleine Hitze 8 Min, wenden. Fertig!</div>
            </div>
            <div class="sms-conversation" data-conv="1">
              <div class="sms-label" data-i18n="sms_label_1">Alltagshilfe</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_1">Wie sage ich auf Englisch: Ich m&ouml;chte einen Arzttermin verschieben?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_1">I would like to reschedule my doctor's appointment. H&ouml;flicher: Could I please reschedule my appointment?</div>
            </div>
            <div class="sms-conversation" data-conv="2">
              <div class="sms-label" data-i18n="sms_label_2">Wissen &amp; Fakten</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_2">Wie hoch ist die Zugspitze?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_2">Die Zugspitze ist 2.962 m hoch &mdash; Deutschlands h&ouml;chster Berg. Im Winter per Seilbahn erreichbar.</div>
            </div>
            <div class="sms-conversation" data-conv="3">
              <div class="sms-label" data-i18n="sms_label_3">Senioren-Hilfe</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_3">Mein Enkel wird 8. Was schenkt man da?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_3">Tolle Ideen: 1) LEGO-Set 2) Kinderbuch-Reihe 3) Experiment-Baukasten 4) Freizeitpark-Tickets. Budget-Tipp: Buch + S&uuml;&szlig;igkeiten = immer ein Hit!</div>
            </div>
            <div class="sms-conversation" data-conv="4">
              <div class="sms-label" data-i18n="sms_label_4">Ohne Internet</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_4">Bin auf dem Land, kein Internet. N&auml;chster Zug Aachen nach K&ouml;ln?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_4">RE1 f&auml;hrt alle 30 Min, Fahrzeit ca. 50 Min. Letzter Zug ca. 23:30. DB-Hotline: 030 2970.</div>
            </div>
            <div class="sms-conversation" data-conv="5">
              <div class="sms-label" data-i18n="sms_label_5">Nachrichten</div>
              <div class="sms-bubble sms-sent" data-i18n="sms_q_5">Aktuelle Nachrichten von Bild?</div>
              <div class="sms-bubble sms-received" data-i18n="sms_a_5">Iran-Israel Konflikt eskaliert &mdash; Gaspreise +35%. Gletscher schmelzen bis 2030er. 1/3 Kliniken vor Insolvenz. VW zahlt Boni. Nagelsmann w&auml;hlt DFB-Team. bild.de</div>
            </div>
            <div class="sms-conversation" data-conv="6">
              <div class="sms-label" data-i18n="sb2_conv_label">So funktioniert's</div>
              <div class="sms-bubble sms-sent">START</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_welcome">Willkommen bei FragSMS! Du chattest mit einer KI, nicht mit einem Menschen.<br><br>Antworte JA = Nutzungsbedingungen + Datenschutz akzeptiert.<br><br>Abmelden: STOP senden.</div>
              <div class="sms-bubble sms-sent">JA</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_confirm">Du bist dabei! 10 Nachrichten/Monat kostenlos (max. 2/Tag). Stell jetzt deine erste Frage!</div>
              <div class="sms-bubble sms-sent" data-i18n="sb2_conv_question">Was ist die Hauptstadt von Australien?</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_answer">Die Hauptstadt von Australien ist Canberra &mdash; nicht Sydney, wie viele denken!</div>
            </div>
            <div class="sms-conversation" data-conv="7">
              <div class="sms-label" data-i18n="sb2_stop_label">Abmeldung</div>
              <div class="sms-bubble sms-sent">STOP</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_stop_reply">Abgemeldet. Dein Chatverlauf wurde gel&ouml;scht. Du erh&auml;ltst keine weiteren SMS. Jederzeit zur&uuml;ckkehren mit START. fragsms.de</div>
            </div>
          </div>
          <div class="phone-dots">
            <button class="dot active" data-dot="0" aria-label="Beispiel 1"></button>
            <button class="dot" data-dot="1" aria-label="Beispiel 2"></button>
            <button class="dot" data-dot="2" aria-label="Beispiel 3"></button>
            <button class="dot" data-dot="3" aria-label="Beispiel 4"></button>
            <button class="dot" data-dot="4" aria-label="Beispiel 5"></button>
            <button class="dot" data-dot="5" aria-label="Beispiel 6"></button>
            <button class="dot" data-dot="6" aria-label="Anmeldung"></button>
            <button class="dot" data-dot="7" aria-label="Abmeldung"></button>
          </div>
        </div>
      </div>

      <!-- Right: Text -->
      <div class="sb-text fade-in">
        <span class="pill" data-i18n="sb1_pill">Wie es funktioniert</span>
        <h2 class="sb-title" data-i18n="sb1_title">Frag einfach.<br>Per SMS.</h2>
        <p class="sb-desc" data-i18n="sb1_desc">
          Schreibe deine Frage als SMS. Unsere KI antwortet auf Deutsch &mdash; direkt in Sekunden.
          Rezepte, &Uuml;bersetzungen, Fakten, Reisetipps &mdash; alles m&ouml;glich.
        </p>
        <div class="sb2-steps">
          <div class="sb2-step">
            <div class="sb2-step-num">1</div>
            <div class="sb2-step-body">
              <div class="sb2-step-title" data-i18n="step1_title">START senden</div>
              <div class="sb2-step-desc" data-i18n="step1_desc">Sende <strong style="color:var(--color-primary)">START</strong> per SMS an unsere +49 Nummer und du bist sofort dabei.</div>
            </div>
          </div>
          <div class="sb2-step">
            <div class="sb2-step-num">2</div>
            <div class="sb2-step-body">
              <div class="sb2-step-title" data-i18n="step2_title">Frag was du willst</div>
              <div class="sb2-step-desc" data-i18n="step2_desc">Schreibe deine Frage. Die KI antwortet auf Deutsch &mdash; in Sekunden.</div>
            </div>
          </div>
          <div class="sb2-step">
            <div class="sb2-step-num sb2-stop">STOP</div>
            <div class="sb2-step-body">
              <div class="sb2-step-title" data-i18n="step3_title">STOP = Alles gel&ouml;scht</div>
              <div class="sb2-step-desc" data-i18n="step3_desc">Sende <strong style="color:var(--color-error)">STOP</strong> &mdash; sofort abgemeldet, alle Daten unwiderruflich gel&ouml;scht.</div>
            </div>
          </div>
        </div>
        <a href="#pricing-heading" class="btn-primary" style="margin-top: 1.5rem; display: inline-flex; align-items: center; gap: 0.5rem;" data-i18n="sb2_cta">
          Kostenlos starten &rarr;
        </a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SWITCHBACK 3 — Privacy & EU data (icon visual right)
  ════════════════════════════════════════════════ -->
  <section class="sb-section" aria-labelledby="features-heading">
    <div class="container sb-grid">

      <!-- Left: Privacy visual -->
      <div class="sb-media fade-in">
        <div class="privacy-card">
          <div class="privacy-row">
            <div class="privacy-icon">
              <svg viewBox="0 0 810 540" width="32" height="22"><rect width="810" height="540" fill="#003399"/><g fill="#FC0" transform="translate(405,270)"><g id="fs12b"><g id="fs6b"><g id="fs2b"><path id="fs1b" d="M0,-120 11.2,-36.9 95.1,-73.1 36.9,-11.2 73.1,-95.1 0,-33.5 -73.1,-95.1 -36.9,-11.2 -95.1,-73.1 -11.2,-36.9z"/><use href="#fs1b" transform="rotate(30)"/></g><use href="#fs2b" transform="rotate(60)"/></g><use href="#fs6b" transform="rotate(180)"/></g></g></svg>
            </div>
            <div>
              <div class="privacy-label" data-i18n="pv_eu_title">EU-Server &amp; DSGVO</div>
              <div class="privacy-sub" data-i18n="pv_eu_sub">Alle Daten bleiben in Europa</div>
            </div>
            <div class="privacy-badge ok" data-i18n="pv_ok">&#10003; Aktiv</div>
          </div>
          <div class="privacy-divider"></div>
          <div class="privacy-row">
            <div class="privacy-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </div>
            <div>
              <div class="privacy-label" data-i18n="pv_enc_title">SHA-256 Verschlüsselung</div>
              <div class="privacy-sub" data-i18n="pv_enc_sub">Nummer nie im Klartext</div>
            </div>
            <div class="privacy-badge ok" data-i18n="pv_ok2">&#10003; Aktiv</div>
          </div>
          <div class="privacy-divider"></div>
          <div class="privacy-row">
            <div class="privacy-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
            </div>
            <div>
              <div class="privacy-label" data-i18n="pv_del_title">STOP = Sofortlöschung</div>
              <div class="privacy-sub" data-i18n="pv_del_sub">Kein Tracking, kein Profiling</div>
            </div>
            <div class="privacy-badge ok" data-i18n="pv_ok3">&#10003; Aktiv</div>
          </div>
          <div class="privacy-divider"></div>
          <div class="privacy-row">
            <div class="privacy-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </div>
            <div>
              <div class="privacy-label" data-i18n="pv_pay_title">Sichere Zahlung</div>
              <div class="privacy-sub" data-i18n="pv_pay_sub">Stripe · SEPA · PayPal</div>
            </div>
            <div class="privacy-badge ok" data-i18n="pv_ok4">&#10003; Aktiv</div>
          </div>
        </div>
      </div>

      <!-- Right: Text -->
      <div class="sb-text fade-in">
        <span class="pill" data-i18n="sb3_pill">Datenschutz &amp; Sicherheit</span>
        <h2 class="sb-title" id="features-heading" data-i18n="sb3_title">Deine Daten.<br>In Europa. Sicher.</h2>
        <p class="sb-desc" data-i18n="sb3_desc">
          Alle Daten werden ausschließlich auf EU-Servern gespeichert.
          Deine Telefonnummer wird per SHA-256 verschlüsselt und nie im Klartext abgelegt.
          Vollständig DSGVO-konform &mdash; von Anfang an.
        </p>
        <ul class="sb-list">
          <li><span class="check">&#10003;</span> <span data-i18n="sb3_l1">100% EU-Datenspeicherung</span></li>
          <li><span class="check">&#10003;</span> <span data-i18n="sb3_l2">Kein Tracking, kein Profiling</span></li>
          <li><span class="check">&#10003;</span> <span data-i18n="sb3_l3">14 Tage Widerrufsrecht</span></li>
        </ul>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRICING
  ════════════════════════════════════════════════ -->
  <section class="pg-section" aria-labelledby="pricing-heading">
    <div class="container">
      <div class="section-heading fade-in">
        <h2 id="pricing-heading"><span class="text-gradient">FragSMS</span> <span data-i18n="pricing_title">Preise</span></h2>
        <p data-i18n="pricing_subtitle">Kostenlos starten. Jederzeit upgraden. Jederzeit k&uuml;ndbar.</p>
      </div>

      <div class="pricing-grid">

        <article class="pricing-card fade-in">
          <div class="pc-name">Free</div>
          <div class="pc-price">&euro;0</div>
          <div class="pc-period" data-i18n="price_per_month">pro Monat</div>
          <ul class="pc-features">
            <li><span class="check">&#10003;</span> <span data-i18n="free_f1">10 Nachrichten / Monat</span></li>
            <li><span class="check">&#10003;</span> <span data-i18n="free_f2">Max. 2 pro Tag</span></li>
            <li><span class="check">&#10003;</span> <span data-i18n="free_f3">Kein Account nötig</span></li>
          </ul>
          <span class="btn-secondary pc-btn" data-i18n="free_cta">Einfach SMS senden</span>
        </article>

