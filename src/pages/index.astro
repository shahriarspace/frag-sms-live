  <script>
    // Phone SMS carousel — Switchback 1
    (function() {
      var screen = document.getElementById('sms-screen');
      if (!screen) return;
      var conversations = screen.querySelectorAll('.sms-conversation');
      var dotsWrap = screen.nextElementSibling;
      var dots = dotsWrap ? dotsWrap.querySelectorAll('.dot') : [];
      var currentIdx = 0;
      var autoTimer;
      function showConv(idx) {
        conversations.forEach(function(c) { c.classList.remove('active'); });
        dots.forEach(function(d) { d.classList.remove('active'); });
        conversations[idx].classList.add('active');
        dots[idx].classList.add('active');
        currentIdx = idx;
      }
      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          showConv(parseInt(dot.getAttribute('data-dot')));
          clearInterval(autoTimer);
          autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
        });
      });
      autoTimer = setInterval(function() { showConv((currentIdx + 1) % conversations.length); }, 5000);
    })();

    // Web signup — phone validation + POST to Worker
    var turnstileToken1 = '';
    var turnstileToken2 = '';
    window.onTurnstileSuccess = function(token) { turnstileToken1 = token; };
    window.onTurnstileSuccess2 = function(token) { turnstileToken2 = token; };

    (function() {
      var SIGNUP_URL = 'https://sms.fragsms.de/signup';

      var pairs = [
        {
          input: 'phone-input', btn: 'start-btn', error: 'phone-error', wrap: 'phone-wrap',
          privacy: 'privacy-check', age: 'age-check', hp: 'hp-field',
          success: 'signup-success', checks: 'signup-checks', sub: 'hero-input-sub',
          getToken: function() { return turnstileToken1; }
        },
        {
          input: 'phone-input-2', btn: 'start-btn-2', error: 'phone-error-2', wrap: 'phone-wrap-2',
          privacy: 'privacy-check-2', age: 'age-check-2', hp: 'hp-field-2',
          success: 'signup-success-2', checks: 'signup-checks-2', sub: null,
          getToken: function() { return turnstileToken2; }
        }
      ];

      function normalizePhone(raw) {
        var s = raw.replace(/[\s\-\(\)\.]/g, '');
        if (s.indexOf('0049') === 0) s = '+49' + s.substring(4);
        if (s.indexOf('0') === 0 && s.indexOf('+') !== 0) s = '+49' + s.substring(1);
        return s;
      }

      function isValidGermanMobile(raw) {
        if (!raw) return false;
        var n = normalizePhone(raw);
        var m = n.match(/^\+49(1[5-7]\d)(\d{7,8})$/);
        return !!m;
      }

      function getLang() {
        try { return localStorage.getItem('fragsms-lang') || 'de'; } catch(e) { return 'de'; }
      }

      function getMsg(key, fallbackDe, fallbackEn) {
        var trans = window.__fragTranslations;
        var lang = getLang();
        if (trans && trans[lang] && trans[lang][key]) return trans[lang][key];
        return lang === 'en' ? fallbackEn : fallbackDe;
      }

      function updateBtnState(p) {
        var input = document.getElementById(p.input);
        var btn = document.getElementById(p.btn);
        var privacyCb = document.getElementById(p.privacy);
        var ageCb = document.getElementById(p.age);
        if (!input || !btn) return;
        var valid = isValidGermanMobile(input.value.trim());
        var checked = privacyCb && privacyCb.checked && ageCb && ageCb.checked;
        btn.disabled = !(valid && checked);
      }

      pairs.forEach(function(p) {
        var input = document.getElementById(p.input);
        var btn = document.getElementById(p.btn);
        var errorEl = document.getElementById(p.error);
        var wrap = document.getElementById(p.wrap);
        var privacyCb = document.getElementById(p.privacy);
        var ageCb = document.getElementById(p.age);
        var hpField = document.getElementById(p.hp);
        var successEl = document.getElementById(p.success);
        var checksEl = document.getElementById(p.checks);
        var subEl = p.sub ? document.getElementById(p.sub) : null;
        if (!input || !btn) return;

        var touched = false;

        // Update button state on checkbox change
        if (privacyCb) privacyCb.addEventListener('change', function() { updateBtnState(p); });
        if (ageCb) ageCb.addEventListener('change', function() { updateBtnState(p); });

        input.addEventListener('input', function() {
          var raw = input.value.trim();
          touched = raw.length > 0;
          var valid = isValidGermanMobile(raw);

          updateBtnState(p);

          if (wrap) {
            wrap.classList.remove('error', 'valid');
            if (touched && valid) wrap.classList.add('valid');
            else if (touched && raw.length >= 4 && !valid) wrap.classList.add('error');
          }

          if (errorEl) {
            if (touched && raw.length >= 4 && !valid) {
              errorEl.textContent = getMsg('phone_error_invalid', 'Bitte gib eine g\u00fcltige deutsche Handynummer ein', 'Please enter a valid German mobile number');
            } else {
              errorEl.textContent = '';
            }
          }
        });

        btn.addEventListener('click', function() {
          var raw = input.value.trim();
          if (!isValidGermanMobile(raw)) return;
          if (privacyCb && !privacyCb.checked) return;
          if (ageCb && !ageCb.checked) return;

          var normalized = normalizePhone(raw);

          // Show loading state
          btn.classList.add('loading');
          btn.disabled = true;
          if (errorEl) errorEl.textContent = '';

          var payload = {
            phone: normalized,
            turnstile_token: p.getToken(),
            website_url: hpField ? hpField.value : ''
          };

          fetch(SIGNUP_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          })
          .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
          .then(function(result) {
            btn.classList.remove('loading');
            if (result.ok && result.data.success) {
              // Show success state, hide form elements
              if (wrap) wrap.style.display = 'none';
              if (checksEl) checksEl.style.display = 'none';
              if (subEl) subEl.style.display = 'none';
              if (errorEl) errorEl.style.display = 'none';
              if (successEl) successEl.style.display = 'flex';

              if (result.data.already_active) {
                // User is already active
                if (successEl) {
                  var msgP = successEl.querySelector('p');
                  if (msgP) msgP.innerHTML = getMsg('signup_already_active', 'Du bist bereits angemeldet! Sende einfach eine SMS an diese Nummer.', 'You are already signed up! Just send an SMS to this number.');
                }
              }
            } else {
              // Show error
              if (errorEl) errorEl.textContent = result.data.error || getMsg('signup_error', 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.', 'An error occurred. Please try again.');
              updateBtnState(p);
            }
          })
          .catch(function() {
            btn.classList.remove('loading');
            if (errorEl) errorEl.textContent = getMsg('signup_error', 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.', 'An error occurred. Please try again.');
            updateBtnState(p);
          });
        });
      });
    })();
  </script>

