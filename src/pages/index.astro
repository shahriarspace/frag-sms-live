      var p = {
        input: 'phone-input', btn: 'start-btn', error: 'phone-error', wrap: 'phone-wrap',
        privacy: 'privacy-check', age: 'age-check', hp: 'hp-field',
        success: 'signup-success', checks: 'signup-checks', sub: 'hero-input-sub',
        getToken: function() { return turnstileToken1; }
      };

      function normalizePhone(raw) {
        // User only types digits after +49 (the prefix is static in the UI)
        var s = raw.replace(/[\s\-\(\)\.]/g, '');
        // Strip leading zero (user typed 0151... but +49 is already shown)
        if (s.indexOf('0') === 0) s = s.substring(1);
        // Strip +49 or 0049 if user pasted a full number
        if (s.indexOf('+49') === 0) s = s.substring(3);
        if (s.indexOf('0049') === 0) s = s.substring(4);
        return '+49' + s;
      }

      function classifyGermanNumber(raw) {
        // Returns: 'mobile', 'landline', or 'invalid'
        if (!raw) return 'invalid';
        var n = normalizePhone(raw);
        // Must be +49 followed by 9-12 digits
        var m = n.match(/^\+49(\d{9,12})$/);
        if (!m) return 'invalid';
        var local = m[1];
        // German mobile prefixes: 15x, 16x, 17x
        if (/^1[567]/.test(local)) return 'mobile';
        // Landline prefixes: 02x-09x, 1[0-4]x, 1[89]x, etc.
        return 'landline';
      }

      function getLang() {
        try { return localStorage.getItem('fragsms-lang') || 'de'; } catch(e) { return 'de'; }
      }

      function getMsg(key, fallbackDe, fallbackEn) {
        var trans = window.__fragTranslations;
        var lang = getLang();
        if (trans && trans[lang] && trans[lang][key]) return trans[lang][key];
        return lang === 'en' ? fallbackEn : fallbackDe;
      }

      function updateBtnState() {
        var input = document.getElementById(p.input);
        var btn = document.getElementById(p.btn);
        var privacyCb = document.getElementById(p.privacy);
        var ageCb = document.getElementById(p.age);
        if (!input || !btn) return;
        var valid = classifyGermanNumber(input.value.trim()) === 'mobile';
        var checked = privacyCb && privacyCb.checked && ageCb && ageCb.checked;
        // Button is enabled when phone is valid (checkboxes validated on click)
        btn.disabled = !valid;
        // Visual feedback: button looks fully active only when both phone + checks are good
        if (valid && checked) {
          btn.classList.add('ready');
        } else {
          btn.classList.remove('ready');
        }
      }

      var input = document.getElementById(p.input);
      var btn = document.getElementById(p.btn);
      var errorEl = document.getElementById(p.error);
      var wrap = document.getElementById(p.wrap);
      var privacyCb = document.getElementById(p.privacy);
      var ageCb = document.getElementById(p.age);
      var hpField = document.getElementById(p.hp);
      var successEl = document.getElementById(p.success);
      var checksEl = document.getElementById(p.checks);
      var subEl = document.getElementById(p.sub);
      if (!input || !btn) return;

      var touched = false;
      var submitting = false;

      // Auto-strip leading zero on input
      input.addEventListener('input', function() {
        var v = input.value;
        // If user types or pastes leading zero, strip it
        if (v.length > 0 && v.charAt(0) === '0') {
          input.value = v.replace(/^0+/, '');
          v = input.value;
        }
        // If user pasted full +49 or 0049 number, strip prefix
        var stripped = v.replace(/[\s\-\(\)\.]/g, '');
        if (stripped.indexOf('+49') === 0) {
          input.value = stripped.substring(3);
          v = input.value;
        } else if (stripped.indexOf('0049') === 0) {
          input.value = stripped.substring(4);
          v = input.value;
        }

        var raw = v.trim();
        touched = raw.length > 0;
        var cls = classifyGermanNumber(raw);

        updateBtnState();

        if (wrap) {
          wrap.classList.remove('error', 'valid');
          if (touched && cls === 'mobile') wrap.classList.add('valid');
          else if (touched && raw.length >= 4 && cls !== 'mobile') wrap.classList.add('error');
        }

        if (errorEl) {
          if (touched && raw.length >= 4 && cls === 'landline') {
            errorEl.textContent = getMsg('phone_error_landline', 'FragSMS funktioniert nur mit Mobilfunknummern (015x, 016x, 017x)', 'FragSMS only works with mobile numbers (015x, 016x, 017x)');
          } else if (touched && raw.length >= 4 && cls === 'invalid') {
            errorEl.textContent = getMsg('phone_error_invalid', 'Bitte gib eine gueltige deutsche Handynummer ein', 'Please enter a valid German mobile number');
          } else {
            errorEl.textContent = '';
          }
        }
      });

      if (privacyCb) privacyCb.addEventListener('change', function() { updateBtnState(); clearCheckboxHint(); });
      if (ageCb) ageCb.addEventListener('change', function() { updateBtnState(); clearCheckboxHint(); });

      var checkboxHintEl = document.getElementById('checkbox-hint');

      function clearCheckboxHint() {
        if (checkboxHintEl) checkboxHintEl.textContent = '';
        if (checksEl) checksEl.classList.remove('shake');
        var labels = checksEl ? checksEl.querySelectorAll('.signup-check') : [];
        for (var i = 0; i < labels.length; i++) labels[i].classList.remove('unchecked-highlight');
      }

      function showCheckboxHint() {
        var unchecked = [];
        if (privacyCb && !privacyCb.checked) unchecked.push(privacyCb);
        if (ageCb && !ageCb.checked) unchecked.push(ageCb);
        if (unchecked.length === 0) return;

        if (checkboxHintEl) {
          checkboxHintEl.textContent = getMsg('signup_checkbox_required',
            'Bitte stimme den Nutzungsbedingungen und der Datenschutzerkl\u00e4rung zu.',
            'Please agree to the Terms of Service and Privacy Policy.');
        }
        // Highlight unchecked labels and shake
        for (var i = 0; i < unchecked.length; i++) {
          var lbl = unchecked[i].closest('.signup-check');
          if (lbl) lbl.classList.add('unchecked-highlight');
        }
        if (checksEl) {
          checksEl.classList.remove('shake');
          void checksEl.offsetWidth; // force reflow for re-trigger
          checksEl.classList.add('shake');
        }
      }

      btn.addEventListener('click', function() {
        if (submitting) return;
        var raw = input.value.trim();
        if (classifyGermanNumber(raw) !== 'mobile') return;
        var checked = privacyCb && privacyCb.checked && ageCb && ageCb.checked;
        if (!checked) {
          showCheckboxHint();
          return;
        }

        submitting = true;
        var normalized = normalizePhone(raw);

        btn.classList.add('loading');
        btn.disabled = true;
        if (errorEl) errorEl.textContent = '';

        var payload = {
          phone: normalized,
          turnstile_token: p.getToken(),
          website_url: hpField ? hpField.value : ''
        };

        fetch(SIGNUP_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function(res) { return res.json().then(function(data) { return { ok: res.ok, data: data }; }); })
        .then(function(result) {
          btn.classList.remove('loading');
          if (result.ok && result.data.success) {
            if (wrap) wrap.style.display = 'none';
            if (checksEl) checksEl.style.display = 'none';
            if (subEl) subEl.style.display = 'none';
            if (errorEl) errorEl.style.display = 'none';
            if (successEl) successEl.style.display = 'flex';

            if (result.data.already_active) {
              if (successEl) {
                var msgP = successEl.querySelector('p');
                if (msgP) msgP.innerHTML = getMsg('signup_already_active', 'Du bist bereits angemeldet! Sende einfach eine SMS an <a href="sms:+4915908138432?body=START" class="sms-link"><strong>+49 1590 8138432</strong></a>.', 'You are already signed up! Just send an SMS to <a href="sms:+4915908138432?body=START" class="sms-link"><strong>+49 1590 8138432</strong></a>.');
              }
            }
          } else {
            submitting = false;
            if (errorEl) errorEl.textContent = result.data.error || getMsg('signup_error', 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.', 'An error occurred. Please try again.');
            updateBtnState();
          }
        })
        .catch(function() {
          btn.classList.remove('loading');
          submitting = false;
          if (errorEl) errorEl.textContent = getMsg('signup_error', 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.', 'An error occurred. Please try again.');
          updateBtnState();
        });
      });
    })();
  </script>

