---
import Base from '../layouts/Base.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Brauche ich ein Smartphone für FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. FragSMS funktioniert mit jedem Handy, das SMS senden kann — auch mit älteren Feature Phones und Prepaid-Handys." } },
    { "@type": "Question", "name": "Brauche ich Internet oder WLAN für FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. FragSMS funktioniert komplett über SMS im Mobilfunknetz. Kein WLAN, kein Datenplan und keine App nötig." } },
    { "@type": "Question", "name": "Kann ich ChatGPT per SMS nutzen?", "acceptedAnswer": { "@type": "Answer", "text": "Mit FragSMS kannst du einen KI-Assistenten per SMS nutzen - ähnlich wie ChatGPT, aber ohne App und ohne Internet. Einfach eine SMS senden und sofort eine KI-Antwort erhalten." } },
    { "@type": "Question", "name": "Wie kündige ich mein FragSMS Abo?", "acceptedAnswer": { "@type": "Answer", "text": "Sende einfach STOP per SMS oder nutze den 'Jetzt kündigen' Button auf fragsms.de/upgrade. Die Kündigung ist sofort wirksam, ohne Wartezeit." } },
    { "@type": "Question", "name": "Sind meine Daten bei FragSMS sicher?", "acceptedAnswer": { "@type": "Answer", "text": "Ja. FragSMS erkennt persoenliche Daten wie Telefonnummern, E-Mail-Adressen und IBANs automatisch und blockiert die Nachricht, bevor sie die KI erreicht. Alle Daten werden ausschliesslich auf EU-Servern gespeichert. Deine Telefonnummer wird per SHA-256 verschluesselt und nie im Klartext gespeichert. FragSMS ist vollstaendig DSGVO-konform." } },
    { "@type": "Question", "name": "Was kostet FragSMS?", "acceptedAnswer": { "@type": "Answer", "text": "FragSMS bietet einen kostenlosen Tarif mit 50 Nachrichten pro Monat inkl. Web-Suche. Plus kostet 4,99 EUR/Monat (50 Nachrichten, mehr Verlauf) und Flat kostet 14,99 EUR/Monat (1000 Nachrichten, maximaler Verlauf). Alle Preise sind Endpreise." } }
  ]
};

const serviceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "FragSMS",
  "description": "KI-Assistent per SMS in Deutschland. Stelle Fragen per SMS und erhalte sofort KI-Antworten.",
  "provider": { "@type": "Organization", "name": "FragSMS", "url": "https://fragsms.de" },
  "areaServed": { "@type": "Country", "name": "Germany" },
  "serviceType": "KI-Assistent per SMS",
  "offers": [
    { "@type": "Offer", "name": "FragSMS Free", "price": "0", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "FragSMS Plus", "price": "4.99", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "FragSMS Flat", "price": "14.99", "priceCurrency": "EUR" }
  ]
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://fragsms.de/" }]
};
---

<Base
  title="FragSMS — KI-Assistent per SMS | ChatGPT per SMS in Deutschland"
  description="FragSMS ist dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Stelle Fragen per SMS und erhalte sofort Antworten. DSGVO-konform, EU-Daten. Ab 0 EUR kostenlos testen."
  keywords="KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, AI SMS ohne App, DSGVO KI Assistent, KI ohne Smartphone, KI ohne Internet, FragSMS, kuenstliche Intelligenz SMS, SMS AI Deutschland"
  jsonLd={[faqJsonLd, serviceJsonLd, breadcrumbJsonLd]}
>

  <!-- ═══════════════════════════════════════════════
       HERO — What is FragSMS?
  ════════════════════════════════════════════════ -->
  <section class="hero-section min-h-[min(100vh-65px,900px)] flex items-center justify-center relative overflow-hidden py-8">
    <div class="hero-glow"></div>
    <canvas class="absolute inset-0 w-full h-full pointer-events-none z-0" id="hero-particles" aria-hidden="true"></canvas>
    <div class="container relative z-[1]">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center max-w-content-wide mx-auto md:text-left text-center">
        <div class="flex flex-col items-center md:items-start fade-in">
          <span class="inline-block px-4 py-1.5 rounded-pill text-[0.78rem] font-bold tracking-[0.04em] uppercase bg-th-primary-glow text-th-primary border border-th-primary-border mb-1" data-i18n="hero_badge">KI per SMS in Deutschland</span>
          <h1 class="text-hero mt-2 mb-3">
            <span data-i18n="hero_title_1">Dein KI-Assistent.</span><br>
            <span class="text-gradient" data-i18n="hero_title_2">Per SMS.</span>
          </h1>
          <p class="text-[clamp(1rem,2vw,1.15rem)] text-th-muted max-w-[480px] mb-4 leading-relaxed text-center md:text-left" data-i18n="hero_subtitle">
            Wie ChatGPT &mdash; aber per SMS. Kein App, kein Internet, kein Login. Einfach fragen.
          </p>
          <ul class="list-none space-y-1.5 mb-5 text-left inline-flex flex-col md:flex md:flex-col">
            <li class="flex items-center gap-2 text-[0.9rem] text-th-muted"><span class="text-th-primary font-bold text-base">&#10003;</span> <span data-i18n="sb1_l1">Kein Smartphone erforderlich</span></li>
            <li class="flex items-center gap-2 text-[0.9rem] text-th-muted"><span class="text-th-primary font-bold text-base">&#10003;</span> <span data-i18n="sb1_l2">Kein Internet oder WLAN</span></li>
            <li class="flex items-center gap-2 text-[0.9rem] text-th-muted"><span class="text-th-primary font-bold text-base">&#10003;</span> <span data-i18n="sb1_l3">Antwort in unter 5 Sekunden</span></li>
          </ul>
          <a href="sms:+4915908138432?body=START" class="btn-primary hero-cta inline-flex items-center gap-2 py-3.5 px-8 text-[1.05rem] font-bold rounded-xl relative shadow-[0_0_20px_rgba(16,185,129,0.25),0_0_60px_rgba(16,185,129,0.1)] animate-glow-pulse" data-i18n="hero_cta">
            Jetzt per SMS starten &rarr;
          </a>
          <div class="hero-desktop-hint hidden md:block mt-2 text-left">
            <p class="text-[0.82rem] text-th-muted mb-0.5" data-i18n="hero_desktop_num">Am Computer? Sende <strong>START</strong> an:</p>
            <p class="text-xl font-extrabold text-th-primary tracking-wide cursor-pointer select-all hover:underline" onclick="navigator.clipboard&&navigator.clipboard.writeText('+4915908138432')">+49 1590 8138432 <span class="text-[0.7rem] font-normal text-th-muted" data-i18n="hero_copy_hint">(klicken zum Kopieren)</span></p>
          </div>
          <p class="mt-2 text-[0.78rem] text-th-muted text-center md:text-left" data-i18n="hero_input_sub">
            50 kostenlose Nachrichten pro Monat &mdash; kein Abo, kein Risiko
          </p>
          <p class="mt-1 text-[0.72rem] text-th-muted opacity-70 text-center md:text-left" data-i18n="hero_sms_cost">
            SMS-Kosten: dein normaler SMS-Tarif (in den meisten Flatrates enthalten)
          </p>
        </div>

        <div class="flex justify-center items-end gap-6 md:gap-8 fade-in">
          <!-- Nokia 3310 mockup (photo) -->
          <div class="nokia-mockup hidden sm:flex flex-col items-center -rotate-3 hover:rotate-0 transition-transform duration-500 shrink-0" aria-label="Nokia 3310 mit FragSMS">
            <div class="nokia-wrapper relative" style="width:180px;height:331px;">
              <img src="/images/nokia-3310.png" alt="Nokia 3310" width="180" height="331" class="w-full h-full object-contain" style="filter:drop-shadow(0 16px 40px rgba(0,0,0,0.4)) drop-shadow(0 0 20px rgba(16,185,129,0.06));" loading="eager" />
              <!-- SMS content overlay on screen -->
              <div class="nokia-screen-overlay absolute" style="top:27.6%;left:24.6%;width:47.3%;height:18%;overflow:hidden;padding:4px;background:#90b468;border-radius:2px;">
                <div class="font-mono whitespace-pre-wrap font-bold" style="color:#2a3a1e;font-size:8px;line-height:1.25;">
                  <div>&gt; Zug K&ouml;ln-M&uuml;nchen?</div>
                  <div style="margin-top:3px;">ICE 1601 14:22 Gl.8</div>
                </div>
              </div>
            </div>
            <span class="mt-3 text-[0.7rem] text-th-muted font-semibold" data-i18n="nokia_label">Auch ohne Smartphone</span>
          </div>

          <!-- Smartphone mockup -->
          <div class="phone-mockup w-phone bg-th-phone-bg rounded-phone p-3 border-2 border-th-phone-border">
            <div class="w-notch h-1.5 bg-th-phone-border rounded-sm mx-auto mt-1 mb-2"></div>
            <div class="text-center py-2 pb-3 border-b border-th-phone-border mb-2">
              <div class="text-[0.7rem] text-th-muted uppercase tracking-[0.05em]">SMS</div>
              <div class="text-base font-bold text-th-text">FragSMS</div>
              <a href="sms:+4915908138432" class="sms-link text-[0.7rem] text-th-muted">+49 1590 8138432</a>
            </div>
            <div class="phone-screen h-phone-screen overflow-y-auto px-1 py-2" id="sms-screen">
              <div class="sms-conversation active" data-conv="0">
                <div class="sms-label" data-i18n="sms_label_0">Kochen &amp; Rezepte</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_0">Was kann ich mit Kartoffeln, Zwiebeln und Eiern kochen?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_0">Spanische Tortilla! Kartoffeln d&uuml;nn schneiden, in &Ouml;l 15 Min braten. Zwiebel dazu. 6 Eier verquirlen, salzen, dazugeben. Kleine Hitze 8 Min, wenden. Fertig!</div>
              </div>
              <div class="sms-conversation" data-conv="1">
                <div class="sms-label" data-i18n="sms_label_1">Alltagshilfe</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_1">Wie sage ich auf Englisch: Ich m&ouml;chte einen Arzttermin verschieben?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_1">I would like to reschedule my doctor's appointment. H&ouml;flicher: Could I please reschedule my appointment?</div>
              </div>
              <div class="sms-conversation" data-conv="2">
                <div class="sms-label" data-i18n="sms_label_2">Wissen &amp; Fakten</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_2">Wie hoch ist die Zugspitze?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_2">Die Zugspitze ist 2.962 m hoch &mdash; Deutschlands h&ouml;chster Berg. Im Winter per Seilbahn erreichbar.</div>
              </div>
              <div class="sms-conversation" data-conv="3">
                <div class="sms-label" data-i18n="sms_label_3">Senioren-Hilfe</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_3">Mein Enkel wird 8. Was schenkt man da?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_3">Tolle Ideen: 1) LEGO-Set 2) Kinderbuch-Reihe 3) Experiment-Baukasten 4) Freizeitpark-Tickets. Budget-Tipp: Buch + S&uuml;&szlig;igkeiten = immer ein Hit!</div>
              </div>
              <div class="sms-conversation" data-conv="4">
                <div class="sms-label" data-i18n="sms_label_4">Ohne Internet</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_4">Bin auf dem Land, kein Internet. N&auml;chster Zug Aachen nach K&ouml;ln?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_4">RE1 f&auml;hrt alle 30 Min, Fahrzeit ca. 50 Min. Letzter Zug ca. 23:30. DB-Hotline: 030 2970.</div>
              </div>
              <div class="sms-conversation" data-conv="5">
                <div class="sms-label" data-i18n="sms_label_5">Nachrichten</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_5">Aktuelle Nachrichten von Bild?</div>
                <div class="sms-bubble sms-received" data-i18n="sms_a_5">Iran-Israel Konflikt eskaliert &mdash; Gaspreise +35%. Gletscher schmelzen bis 2030er. 1/3 Kliniken vor Insolvenz. VW zahlt Boni. Nagelsmann w&auml;hlt DFB-Team. bild.de</div>
              </div>
              <div class="sms-conversation" data-conv="6">
                <div class="sms-label" data-i18n="sms_label_6">Datenschutz</div>
                <div class="sms-bubble sms-sent" data-i18n="sms_q_6">Schick meine IBAN DE89370400440532013000 an meinen Steuerberater</div>
                <div class="sms-bubble sms-received sms-privacy-warn" data-i18n="sms_a_6">Deine Nachricht enth&auml;lt pers&ouml;nliche Daten (IBAN). Bitte sende keine sensiblen Infos per SMS. Formuliere deine Frage ohne IBAN neu.</div>
              </div>
            </div>
            <div class="flex justify-center gap-1.5 pt-3 pb-2">
              <button class="dot active" data-dot="0" aria-label="Beispiel 1"></button>
              <button class="dot" data-dot="1" aria-label="Beispiel 2"></button>
              <button class="dot" data-dot="2" aria-label="Beispiel 3"></button>
              <button class="dot" data-dot="3" aria-label="Beispiel 4"></button>
              <button class="dot" data-dot="4" aria-label="Beispiel 5"></button>
              <button class="dot" data-dot="5" aria-label="Beispiel 6"></button>
              <button class="dot" data-dot="6" aria-label="Beispiel 7"></button>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       STATS BAR
  ════════════════════════════════════════════════ -->
  <section class="stats-bar border-t border-b border-th-border py-8 bg-th-bg-alt relative">
    <div class="container flex items-center justify-center flex-wrap gap-y-4">
      <div class="flex flex-col items-center px-6 sm:px-12 text-center fade-in">
        <span class="text-stat text-th-primary">100%</span>
        <span class="text-[0.78rem] text-th-muted mt-1 uppercase tracking-wider font-semibold" data-i18n="stat1">DSGVO-konform</span>
      </div>
      <div class="stat-divider w-px h-stat-divider bg-th-border shrink-0 hidden sm:block"></div>
      <div class="flex flex-col items-center px-6 sm:px-12 text-center fade-in">
        <span class="text-stat text-th-primary">EU</span>
        <span class="text-[0.78rem] text-th-muted mt-1 uppercase tracking-wider font-semibold" data-i18n="stat2">Server &amp; Datenschutz</span>
      </div>
      <div class="stat-divider w-px h-stat-divider bg-th-border shrink-0 hidden sm:block"></div>
      <div class="flex flex-col items-center px-6 sm:px-12 text-center fade-in">
        <span class="text-stat text-th-primary">&euro;0</span>
        <span class="text-[0.78rem] text-th-muted mt-1 uppercase tracking-wider font-semibold" data-i18n="stat3">Kostenlos starten</span>
      </div>
      <div class="stat-divider w-px h-stat-divider bg-th-border shrink-0 hidden sm:block"></div>
      <div class="flex flex-col items-center px-6 sm:px-12 text-center fade-in">
        <span class="text-stat text-th-primary">&#128241;</span>
        <span class="text-[0.78rem] text-th-muted mt-1 uppercase tracking-wider font-semibold" data-i18n="stat4">Jedes Handy</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       HOW IT WORKS — 3 Steps (text left, phone mockup right)
  ════════════════════════════════════════════════ -->
  <section class="py-24 bg-th-bg-alt" aria-labelledby="how-it-works">
    <div class="container grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center max-w-content-wide mx-auto md:[direction:rtl]">

      <!-- Left: Text + Steps -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left [direction:ltr] fade-in">
        <span class="inline-block px-4 py-1.5 rounded-pill text-[0.78rem] font-bold tracking-[0.04em] uppercase bg-th-primary-glow text-th-primary border border-th-primary-border mb-1" data-i18n="sb2_pill">In 3 Schritten</span>
        <h2 class="text-section mt-2 mb-4" id="how-it-works" data-i18n="sb2_title">In Sekunden<br>startklar.</h2>
        <p class="text-base text-th-muted leading-relaxed max-w-sb-desc mb-6" data-i18n="sb2_desc">
          Keine Registrierung, kein App-Download, kein Passwort.
          Einfach eine SMS senden und sofort loslegen.
        </p>
        <div class="mt-6 flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <div class="w-step-num h-step-num rounded-step bg-th-primary-glow border border-th-primary-border flex items-center justify-center text-[0.9rem] font-extrabold text-th-primary shrink-0">1</div>
            <div class="flex-1">
              <div class="font-bold text-[0.9rem] mb-0.5" data-i18n="step1_title">START senden</div>
              <div class="text-[0.8rem] text-th-muted leading-relaxed" data-i18n="step1_desc">Sende <strong style="color:var(--color-primary)">START</strong> per SMS an <a href="sms:+4915908138432?body=START" class="sms-link"><strong>+49 1590 8138432</strong></a> und du bist sofort dabei.</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-step-num h-step-num rounded-step bg-th-primary-glow border border-th-primary-border flex items-center justify-center text-[0.9rem] font-extrabold text-th-primary shrink-0">2</div>
            <div class="flex-1">
              <div class="font-bold text-[0.9rem] mb-0.5" data-i18n="step2_title">Frag was du willst</div>
              <div class="text-[0.8rem] text-th-muted leading-relaxed" data-i18n="step2_desc">Schreibe deine Frage. Die KI antwortet auf Deutsch &mdash; in Sekunden.</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-step-num h-step-num rounded-step bg-[rgba(239,68,68,0.1)] border border-[rgba(239,68,68,0.3)] flex items-center justify-center text-[0.9rem] font-extrabold text-th-error shrink-0">3</div>
            <div class="flex-1">
              <div class="font-bold text-[0.9rem] mb-0.5" data-i18n="step3_title">STOP = Alles gel&ouml;scht</div>
              <div class="text-[0.8rem] text-th-muted leading-relaxed" data-i18n="step3_desc">Sende <strong style="color:var(--color-error)">STOP</strong> &mdash; sofort abgemeldet, alle Daten unwiderruflich gel&ouml;scht.</div>
            </div>
          </div>
        </div>
        <a href="sms:+4915908138432?body=START" class="btn-primary mt-6 inline-flex items-center gap-2" data-i18n="sb2_cta">
          Kostenlos starten &rarr;
        </a>
      </div>

      <!-- Right: Phone mockup — onboarding carousel -->
      <div class="flex justify-center [direction:ltr] fade-in">
        <div class="phone-mockup w-phone bg-th-phone-bg rounded-phone p-3 border-2 border-th-phone-border">
          <div class="w-notch h-1.5 bg-th-phone-border rounded-sm mx-auto mt-1 mb-2"></div>
          <div class="text-center py-2 pb-3 border-b border-th-phone-border mb-2">
            <div class="text-[0.7rem] text-th-muted uppercase tracking-[0.05em]">SMS</div>
            <div class="text-base font-bold text-th-text">FragSMS</div>
            <a href="sms:+4915908138432" class="sms-link text-[0.7rem] text-th-muted">+49 1590 8138432</a>
          </div>
          <div class="phone-screen h-phone-screen overflow-y-auto px-1 py-2" id="onboarding-screen">
            <div class="sms-conversation active">
              <div class="sms-label" data-i18n="sb2_conv_label">So funktioniert's</div>
              <div class="sms-bubble sms-sent">START</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_welcome">Willkommen bei FragSMS! Du chattest mit einer KI, nicht mit einem Menschen.<br><br>Antworte JA = Nutzungsbedingungen + Datenschutz akzeptiert.<br><br>Abmelden: STOP senden.</div>
              <div class="sms-bubble sms-sent">JA</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_confirm">Du bist dabei! 50 Nachrichten/Monat kostenlos. Stell jetzt deine erste Frage!</div>
              <div class="sms-bubble sms-sent" data-i18n="sb2_conv_question">Was ist die Hauptstadt von Australien?</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_conv_answer">Die Hauptstadt von Australien ist Canberra &mdash; nicht Sydney, wie viele denken!</div>
              <div class="sms-bubble sms-sent">STOP</div>
              <div class="sms-bubble sms-received" data-i18n="sb2_stop_reply">Abgemeldet. Dein Chatverlauf wurde gel&ouml;scht. Du erh&auml;ltst keine weiteren SMS. Jederzeit zur&uuml;ckkehren mit START. fragsms.de</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       USE CASES — Real-world scenarios
  ════════════════════════════════════════════════ -->
  <section class="py-24" aria-labelledby="usecases-heading">
    <div class="container">
      <div class="text-center mb-12 fade-in">
        <h2 id="usecases-heading" class="text-section-sm mb-2"><span data-i18n="uc_title_1">Wann ist</span> <span class="text-gradient" data-i18n="uc_title_2">FragSMS perfekt?</span></h2>
        <p class="text-th-muted text-base max-w-desc mx-auto" data-i18n="uc_subtitle">Echte Situationen, in denen FragSMS den Unterschied macht.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-5 max-w-cards mx-auto">

        <article class="bg-th-surface border border-th-border rounded-card p-8 flex flex-col gap-3 transition-card duration-300 hover:border-th-primary-border hover:shadow-[0_8px_32px_rgba(16,185,129,0.12)] hover:-translate-y-1 fade-in">
          <div class="text-[2rem] leading-none">&#9992;</div>
          <h3 class="text-base font-extrabold text-th-text tracking-[-0.01em]" data-i18n="uc1_title">Urlaub ohne Internet</h3>
          <p class="text-sm text-th-muted leading-[1.7]" data-i18n="uc1_desc">Im Ausland ohne Roaming oder WLAN? Per SMS fragst du nach Restaurants, &Uuml;bersetzungen oder Notfall-Infos &mdash; ganz ohne Datenverbindung.</p>
