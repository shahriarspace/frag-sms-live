    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://fragsms.de/blog/" },
    { "@type": "ListItem", "position": 3, "name": "Wetter per SMS", "item": "https://fragsms.de/blog/wetter-per-sms/" }
  ]
