      letter-spacing: 0.05em;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
    }
    .related-title {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--color-text);
      line-height: 1.4;
    }
  </style>
</Base>
