<Base
  title="Blog &mdash; KI per SMS Ratgeber &amp; Wissen | FragSMS"
  description="Ratgeber, Vergleiche und Wissen rund um KI per SMS in Deutschland. Erfahre, wie du k&uuml;nstliche Intelligenz ohne App und ohne Internet nutzen kannst."
  keywords="KI per SMS Blog, FragSMS Ratgeber, KI ohne Internet, ChatGPT Alternative, DSGVO KI, SMS KI Deutschland"
  jsonLd={breadcrumbJsonLd}
>
  <section style="padding: 4rem 0 6rem;">
    <div class="container" style="max-width: 900px;">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" style="margin-bottom: 2rem; font-size: 0.82rem; color: var(--color-text-muted);">
        <a href="/" style="color: var(--color-text-muted);">Startseite</a>
        <span style="margin: 0 0.5rem;">/</span>
        <span style="color: var(--color-text);" data-i18n="blog_breadcrumb">Blog</span>
      </nav>

      <!-- Header -->
      <header style="margin-bottom: 3rem; text-align: center;">
        <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; letter-spacing: -0.035em; line-height: 1.1; margin-bottom: 1rem;">
          <span data-i18n="blog_page_title_1">Ratgeber &amp;</span> <span class="text-gradient" data-i18n="blog_page_title_2">Wissen</span>
        </h1>
        <p style="font-size: 1.1rem; color: var(--color-text-muted); line-height: 1.7; max-width: 600px; margin: 0 auto;" data-i18n="blog_page_subtitle">
          Alles &uuml;ber KI per SMS, Datenschutz und digitale Teilhabe in Deutschland.
        </p>
      </header>

      <!-- Article grid -->
      <div class="blog-list">
        {articles.map((article) => (
          <a href={`/blog/${article.slug}/`} class="blog-list-card fade-in">
            <div class="blog-list-card-inner">
              <div>
                <div class="blog-list-tag" data-i18n={`blog_idx_tag_${article.slug}`}>{article.tag}</div>
                <h2 class="blog-list-title" data-i18n={`blog_idx_title_${article.slug}`}>{article.title}</h2>
                <p class="blog-list-desc" data-i18n={`blog_idx_desc_${article.slug}`}>{article.desc}</p>
              </div>
              <div class="blog-list-meta">
                <span data-i18n={`blog_idx_date_${article.slug}`}>{article.date}</span>
                <span class="blog-list-dot">&middot;</span>
                <span data-i18n={`blog_idx_time_${article.slug}`}>{article.readTime} Lesezeit</span>
                <span class="blog-list-arrow" data-i18n="blog_idx_read">&rarr; Artikel lesen</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="blog-cta fade-in">
        <p style="font-size: 1.15rem; font-weight: 800; margin-bottom: 0.5rem;" data-i18n="blog_cta_title">Jetzt FragSMS kostenlos testen</p>
        <p style="font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 1.25rem;" data-i18n="blog_cta_desc">50 kostenlose Nachrichten pro Monat &mdash; kein Abo, kein Risiko.</p>
        <a href="/" class="btn-primary" data-i18n="blog_cta_btn">Zur Startseite &rarr;</a>
      </div>

    </div>
  </section>

  <style>
    .blog-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .blog-list-card {
      display: block;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 1.75rem 2rem;
      text-decoration: none;
      transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .blog-list-card:hover {
      border-color: var(--color-primary);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(16, 185, 129, 0.08);
      text-decoration: none;
    }
    .blog-list-card-inner {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .blog-list-tag {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      background: var(--color-primary-glow);
      color: var(--color-primary);
      border: 1px solid var(--color-primary-border);
      margin-bottom: 0.5rem;
    }
    .blog-list-title {
      font-size: 1.35rem;
      font-weight: 800;
      color: var(--color-text);
      letter-spacing: -0.02em;
      line-height: 1.3;
      margin-bottom: 0.5rem;
    }
    .blog-list-desc {
      font-size: 0.92rem;
      color: var(--color-text-muted);
      line-height: 1.6;
    }
    .blog-list-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.8rem;
      color: var(--color-text-muted);
      flex-wrap: wrap;
    }
    .blog-list-dot {
      color: var(--color-border-hover);
    }
    .blog-list-arrow {
      margin-left: auto;
      color: var(--color-primary);
      font-weight: 600;
      font-size: 0.82rem;
    }
    .blog-cta {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      margin-top: 3rem;
      text-align: center;
    }

    @media (max-width: 600px) {
      .blog-list-card {
        padding: 1.25rem 1.25rem;
      }
      .blog-list-title {
        font-size: 1.15rem;
      }
      .blog-list-arrow {
        margin-left: 0;
        margin-top: 0.25rem;
      }
    }
  </style>

