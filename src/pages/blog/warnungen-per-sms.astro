<Base
  title="NINA Warnungen per SMS &mdash; Katastrophenwarnungen ohne App | FragSMS Blog"
  description="Unwetterwarnungen, Zivilschutz und Katastrophenmeldungen per SMS empfangen. FragSMS liefert offizielle NINA/MOWAS-Warnungen direkt aufs Handy &mdash; ohne App und ohne Internet."
  keywords="NINA Warnungen SMS, Katastrophenwarnung SMS, Unwetterwarnung per SMS, Zivilschutz SMS, MOWAS Warnung Handy, FragSMS Warnungen"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  legalPage={true}
>
  <article style="padding: 4rem 0 6rem;">
    <div class="container" style="max-width: 720px;">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" style="margin-bottom: 2rem; font-size: 0.82rem; color: var(--color-text-muted);">
