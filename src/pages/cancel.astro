---
import Base from '../layouts/Base.astro';
---

<Base title="Zahlung abgebrochen — FragSMS" description="Die Zahlung wurde abgebrochen. Du kannst es jederzeit erneut versuchen." noindex={true}>

  <section style="padding: 5rem 0;">
    <div class="container" style="max-width: 540px; text-align: center;">
      <div class="fade-in">
        <div style="font-size: 3rem; margin-bottom: 1.5rem;">&#8592;</div>
        <h1 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 0.75rem;">
          Zahlung <span style="color: var(--color-text-muted);">abgebrochen</span>
        </h1>
        <p style="color: var(--color-text-muted); margin-bottom: 1.5rem; line-height: 1.7;">
          Kein Problem! Es wurde nichts berechnet. Du kannst den Upgrade-Vorgang jederzeit erneut starten.
        </p>
        <p style="color: var(--color-text-muted); margin-bottom: 2rem; font-size: 0.9rem;">
          Dein kostenloser FragSMS Zugang bleibt aktiv.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="/upgrade" class="btn-primary">Erneut versuchen</a>
          <a href="/" class="btn-secondary">Zur Startseite</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 2rem;
    }
  </style>

</Base>
