---
import Base from '../layouts/Base.astro';
---

<Base title="Zahlung abgebrochen — FragSMS" noindex={true}>
  <section style="padding: 4rem 0; text-align: center;">
    <div class="container" style="max-width: 500px;">
      <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem;">
        Zahlung abgebrochen
      </h1>
      <p style="font-size: 1.1rem; margin-bottom: 2rem; color: var(--color-text-muted);">
        Kein Problem! Du kannst jederzeit zur&uuml;ckkommen und upgraden.
        Dein kostenloser Zugang bleibt aktiv.
      </p>

      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/upgrade" style="display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;">
          Erneut versuchen
        </a>
        <a href="/" style="display: inline-block; background: var(--color-bg-alt); color: var(--color-text); padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; border: 1px solid var(--color-border);">
          Zur&uuml;ck zur Startseite
        </a>
      </div>
    </div>
  </section>
</Base>
