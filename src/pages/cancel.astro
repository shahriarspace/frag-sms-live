---
import Base from '../layouts/Base.astro';
---

<Base title="Zahlung abgebrochen — FragSMS" noindex={true}>
  <section class="section" style="text-align: center;">
    <div class="container" style="max-width: 500px;">
      <div class="fade-in">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--color-accent-glow); border: 2px solid var(--color-border); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.5rem; color: var(--color-text-muted);">
          &#10005;
        </div>
        <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem;">
          Zahlung abgebrochen
        </h1>
        <p style="font-size: 1.1rem; margin-bottom: 2.5rem; color: var(--color-text-muted);">
          Kein Problem! Du kannst jederzeit zur&uuml;ckkommen und upgraden.
          Dein kostenloser Zugang bleibt aktiv.
        </p>
      </div>

      <div class="fade-in" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/upgrade" class="btn-primary">
          Erneut versuchen
        </a>
        <a href="/" class="btn-secondary">
          Zur&uuml;ck zur Startseite
        </a>
      </div>
    </div>
  </section>
</Base>
