---
import Base from '../layouts/Base.astro';
---

<Base title="FragSMS Upgrade — Starter, Basic oder Pro Abo | Ab 3,99 EUR/Monat" description="Upgrade dein FragSMS Abo auf Starter (30 Nachrichten, 3,99 EUR), Basic (150 Nachrichten, 9,99 EUR) oder Pro (500 Nachrichten, 19,99 EUR). Web-Suche Add-on fuer 4,99 EUR/Monat. Jederzeit kuendbar." keywords="FragSMS Upgrade, KI SMS Abo, FragSMS Starter, FragSMS Basic, FragSMS Pro, KI Assistent Abo Deutschland">

  <section class="section">
    <div class="container" style="max-width: 640px;">
      <div class="fade-in" style="text-align: center; margin-bottom: 2.5rem;">
        <span class="badge badge-primary" style="margin-bottom: 1rem;" data-i18n="upgrade_badge">Abo verwalten</span>
        <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">
          FragSMS <span class="text-gradient">Upgrade</span>
        </h1>
        <p style="color: var(--color-text-muted);" data-i18n="upgrade_subtitle">
          W&auml;hle deinen Tarif und zahle sicher mit Karte, SEPA oder Sofort.
        </p>
      </div>

      <!-- Upgrade Form -->
      <form id="upgrade-form" class="card fade-in" style="padding: 2rem;">
        <!-- Phone number -->
        <div style="margin-bottom: 1.5rem;">
          <label for="phone" style="display: block; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.9rem;" data-i18n="upgrade_phone_label">
            Deine Handynummer
          </label>
          <div style="display: flex; align-items: center; border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; transition: border-color 0.2s, box-shadow 0.2s;" id="phone-wrap">
            <span style="padding: 0.75rem 0 0.75rem 1rem; font-weight: 700; font-size: 1rem; color: var(--color-text); user-select: none; flex-shrink: 0;">+49</span>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="151 2345 6789"
              required
              style="flex: 1; padding: 0.75rem 1rem 0.75rem 0.5rem; border: none; font-size: 1rem; background: var(--color-bg); color: var(--color-text); outline: none;"
            />
          </div>
          <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.35rem;" data-i18n="upgrade_phone_hint">
            Die Nummer, mit der du FragSMS per SMS nutzt.
          </p>
        </div>

        <!-- Plan selection -->
        <div style="margin-bottom: 1.5rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem; font-size: 0.9rem;" data-i18n="upgrade_plan_label">Tarif w&auml;hlen</p>
          <div style="display: flex; gap: 0.75rem;">
            <label style="flex: 1; border: 1px solid var(--color-border); border-radius: 12px; padding: 1rem; cursor: pointer; text-align: center; transition: border-color 0.2s, box-shadow 0.2s; background: var(--color-bg);" id="plan-starter-label">
              <input type="radio" name="plan" value="starter" required style="display: none;" />
              <div style="font-weight: 700; font-size: 1rem; margin-bottom: 0.25rem;">Starter</div>
              <div style="color: var(--color-primary); font-weight: 800; font-size: 1.2rem; margin-bottom: 0.25rem;">&euro;3,99</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted);" data-i18n="upgrade_starter_msgs">30 Nachr./Monat</div>
            </label>
            <label style="flex: 1; border: 1px solid var(--color-border); border-radius: 12px; padding: 1rem; cursor: pointer; text-align: center; transition: border-color 0.2s, box-shadow 0.2s; background: var(--color-bg); position: relative;" id="plan-basic-label">
              <input type="radio" name="plan" value="basic" style="display: none;" />
              <div style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: var(--color-btn-text); padding: 0.15rem 0.75rem; border-radius: 12px; font-size: 0.65rem; font-weight: 700;" data-i18n="badge_popular">Beliebt</div>
              <div style="font-weight: 700; font-size: 1rem; margin-bottom: 0.25rem;">Basic</div>
              <div style="color: var(--color-primary); font-weight: 800; font-size: 1.2rem; margin-bottom: 0.25rem;">&euro;9,99</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted);" data-i18n="upgrade_basic_msgs">150 Nachr./Monat</div>
            </label>
            <label style="flex: 1; border: 1px solid var(--color-border); border-radius: 12px; padding: 1rem; cursor: pointer; text-align: center; transition: border-color 0.2s, box-shadow 0.2s; background: var(--color-bg);" id="plan-pro-label">
              <input type="radio" name="plan" value="pro" style="display: none;" />
              <div style="font-weight: 700; font-size: 1rem; margin-bottom: 0.25rem;">Pro</div>
              <div style="color: var(--color-primary); font-weight: 800; font-size: 1.2rem; margin-bottom: 0.25rem;">&euro;19,99</div>
              <div style="font-size: 0.75rem; color: var(--color-text-muted);" data-i18n="upgrade_pro_msgs">500 Nachr./Monat</div>
            </label>
          </div>
        </div>

        <!-- Web Search Add-on -->
        <div id="addon-section" style="margin-bottom: 1.5rem; display: none;">
          <div style="border: 1px dashed var(--color-primary-border); border-radius: 12px; padding: 1rem; background: var(--color-primary-glow);">
            <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
              <input type="checkbox" id="cb-addon" style="width: 20px; height: 20px; accent-color: var(--color-primary);" />
              <div style="flex: 1;">
                <div style="font-weight: 700; font-size: 0.95rem;">
                  <span data-i18n="addon_label">&#128269; Web-Suche Add-on</span>
                  <span style="color: var(--color-primary); font-weight: 800; margin-left: 0.5rem;">+&euro;4,99<span style="font-weight: 400; font-size: 0.8rem;">/Mo</span></span>
                </div>
                <div style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.2rem;" data-i18n="addon_desc">200 Web-Suchen/Monat. Aktuelle Infos direkt per SMS.</div>
              </div>
            </label>
          </div>
        </div>

        <!-- Legal checkboxes (mandatory) -->
        <div style="margin-bottom: 1.5rem; font-size: 0.85rem; color: var(--color-text-muted);">
          <label style="display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.75rem; cursor: pointer;">
            <input type="checkbox" id="cb-widerruf" required style="margin-top: 3px; accent-color: var(--color-primary);" />
            <span data-i18n="upgrade_cb_widerruf">
              Ich stimme zu, dass FragSMS sofort beginnt und verzichte auf mein 14-t&auml;giges Widerrufsrecht (&sect;356 Abs. 5 BGB).
            </span>
          </label>
          <label style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" id="cb-datenschutz" required style="margin-top: 3px; accent-color: var(--color-primary);" />
            <span data-i18n="upgrade_cb_datenschutz">
              Ich habe die <a href="/datenschutz" target="_blank">Datenschutzerkl&auml;rung</a> gelesen und stimme zu.
            </span>
          </label>
        </div>

        <!-- Submit button — legally required wording -->
        <button
          type="submit"
          id="submit-btn"
          disabled
          class="btn-primary"
          style="width: 100%; padding: 0.85rem; font-size: 1rem; opacity: 0.4; transition: opacity 0.2s, background 0.2s, transform 0.15s, box-shadow 0.2s;"
        >
          Kostenpflichtig bestellen
        </button>

        <p style="text-align: center; font-size: 0.75rem; color: var(--color-footer-dim); margin-top: 0.75rem;" data-i18n="upgrade_stripe_note">
          Sichere Zahlung &uuml;ber Stripe. Karte, SEPA-Lastschrift oder Sofort&uuml;berweisung.
        </p>

        <!-- Error message area -->
        <div id="error-msg" style="display: none; margin-top: 1rem; padding: 0.75rem; background: var(--color-error-glow); border: 1px solid rgba(239,68,68,0.3); border-radius: 8px; color: var(--color-error); font-size: 0.85rem; text-align: center;">
        </div>
      </form>

      <!-- Jetzt kuendigen — §312k BGB: must be permanently visible -->
      <div class="card fade-in" style="margin-top: 2.5rem; text-align: center; border-color: rgba(239, 68, 68, 0.2);">
        <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;" data-i18n="cancel_heading">Abo k&uuml;ndigen</h2>
        <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1rem;" data-i18n="cancel_desc">
          Du hast bereits ein Abo und m&ouml;chtest k&uuml;ndigen? Gib deine Handynummer ein.
        </p>
        <div style="display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto;">
          <div style="display: flex; align-items: center; flex: 1; border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden;" id="cancel-phone-wrap">
            <span style="padding: 0.6rem 0 0.6rem 0.75rem; font-weight: 700; font-size: 0.9rem; color: var(--color-text); user-select: none; flex-shrink: 0;">+49</span>
            <input
              type="tel"
              id="cancel-phone"
              placeholder="151 2345 6789"
              style="flex: 1; padding: 0.6rem 0.75rem 0.6rem 0.4rem; border: none; font-size: 0.9rem; background: var(--color-bg); color: var(--color-text); outline: none;"
            />
          </div>
          <button
            type="button"
            id="cancel-btn"
            style="padding: 0.6rem 1.25rem; background: var(--color-error); color: white; border: none; border-radius: 8px; font-weight: 600; font-size: 0.9rem; cursor: pointer; white-space: nowrap; transition: background 0.2s;"
          >
            Jetzt k&uuml;ndigen
          </button>
        </div>
        <div style="text-align: center; margin-top: 0.5rem;">
          <button
            type="button"
            id="cancel-addon-btn"
            style="padding: 0.4rem 1rem; background: transparent; color: var(--color-text-muted); border: 1px solid var(--color-border); border-radius: 8px; font-size: 0.8rem; cursor: pointer; transition: border-color 0.2s;"
            data-i18n="cancel_addon_btn"
          >
            Add-on k&uuml;ndigen
          </button>
        </div>
        <div id="cancel-msg" style="display: none; margin-top: 0.75rem; font-size: 0.85rem; text-align: center;"></div>
      </div>
    </div>
  </section>

  <style>
    .section {
      padding: 5rem 0;
    }
    .card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 1.5rem;
    }
    .badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .badge-primary {
      background: var(--color-primary-glow);
      color: var(--color-primary);
      border: 1px solid var(--color-primary-border);
    }
    #phone-wrap:focus-within, #cancel-phone-wrap:focus-within {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px var(--color-primary-glow);
    }
    #plan-starter-label:hover, #plan-basic-label:hover, #plan-pro-label:hover {
      border-color: var(--color-border-hover);
    }
    #cancel-btn:hover {
      background: #dc2626;
    }
  </style>

  <script>
    const STRIPE_WORKER_URL = 'https://stripe.fragsms.de';

    // --- Plan selection highlighting ---
    const planInputs = document.querySelectorAll('input[name="plan"]');
    const planLabels = ['plan-starter-label', 'plan-basic-label', 'plan-pro-label'];
    const addonSection = document.getElementById('addon-section');
    const cbAddon = document.getElementById('cb-addon');

    planInputs.forEach(input => {
      input.addEventListener('change', () => {
        planLabels.forEach(id => {
          document.getElementById(id).style.borderColor = '';
          document.getElementById(id).style.boxShadow = '';
        });
        const labelId = `plan-${input.value}-label`;
        document.getElementById(labelId).style.borderColor = 'var(--color-primary)';
        document.getElementById(labelId).style.boxShadow = '0 0 20px rgba(16, 185, 129, 0.1)';
        addonSection.style.display = 'block';
        checkFormValidity();
      });
    });

    // --- Enable button only when all checkboxes are checked and plan is selected ---
    const cbWiderruf = document.getElementById('cb-widerruf');
    const cbDatenschutz = document.getElementById('cb-datenschutz');
    const submitBtn = document.getElementById('submit-btn');

    function checkFormValidity() {
      const planSelected = document.querySelector('input[name="plan"]:checked');
      const allChecked = cbWiderruf.checked && cbDatenschutz.checked && planSelected;
      submitBtn.disabled = !allChecked;
      submitBtn.style.opacity = allChecked ? '1' : '0.4';
    }

    cbWiderruf.addEventListener('change', checkFormValidity);
    cbDatenschutz.addEventListener('change', checkFormValidity);

    // --- Upgrade form submission ---
    document.getElementById('upgrade-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById('error-msg');
      errorMsg.style.display = 'none';

      const phoneRaw = document.getElementById('phone').value.trim();
      const plan = document.querySelector('input[name="plan"]:checked')?.value;

      if (!phoneRaw || !plan) return;

      if (!isValidGermanMobile(phoneRaw)) {
        if (isLandline(phoneRaw)) {
          errorMsg.textContent = 'FragSMS funktioniert nur mit Mobilfunknummern (015x, 016x, 017x).';
        } else {
          errorMsg.textContent = 'Bitte gib eine gueltige deutsche Handynummer ein (z.B. 151 2345 6789).';
        }
        errorMsg.style.display = 'block';
        return;
      }

      const phone = normalizePhone(phoneRaw);

      submitBtn.disabled = true;
      submitBtn.textContent = 'Bitte warten...';

      try {
        const response = await fetch(`${STRIPE_WORKER_URL}/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone, plan }),
        });

        const data = await response.json();

        if (data.url) {
          // Save addon preference before navigating away
          if (cbAddon && cbAddon.checked) {
            try { localStorage.setItem('fragsms-addon-pending', phone); } catch (e) {}
          }
          window.location.href = data.url;
        } else {
          errorMsg.textContent = data.error || 'Ein Fehler ist aufgetreten.';
          errorMsg.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Kostenpflichtig bestellen';
          checkFormValidity();
        }
      } catch (err) {
        errorMsg.textContent = 'Verbindungsfehler. Bitte versuche es erneut.';
        errorMsg.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Kostenpflichtig bestellen';
        checkFormValidity();
      }

    });

    // --- Phone normalization helper (user types WITHOUT +49 prefix) ---
    function normalizePhone(raw) {
      var s = raw.replace(/[\s\-\(\)\.]/g, '');
      if (s.indexOf('0') === 0) s = s.substring(1);
      if (s.indexOf('+49') === 0) s = s.substring(3);
      if (s.indexOf('0049') === 0) s = s.substring(4);
      return '+49' + s;
    }

    function isValidGermanMobile(raw) {
      if (!raw) return false;
      var n = normalizePhone(raw);
      return /^\+49(1[567]\d)(\d{7,8})$/.test(n);
    }

    function isLandline(raw) {
      if (!raw) return false;
      var n = normalizePhone(raw);
      var m = n.match(/^\+49(\d{9,12})$/);
      if (!m) return false;
      return !/^1[567]/.test(m[1]);
    }

    // Auto-strip leading zero and pasted +49 prefix
    ['phone', 'cancel-phone'].forEach(function(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('input', function() {
        var v = el.value;
        if (v.length > 0 && v.charAt(0) === '0') {
          el.value = v.replace(/^0+/, '');
        }
        var stripped = el.value.replace(/[\s\-\(\)\.]/g, '');
        if (stripped.indexOf('+49') === 0) {
          el.value = stripped.substring(3);
        } else if (stripped.indexOf('0049') === 0) {
          el.value = stripped.substring(4);
        }
      });
    });

    // --- Cancel subscription ---
    document.getElementById('cancel-btn').addEventListener('click', async () => {
      const phoneRaw = document.getElementById('cancel-phone').value.trim();
      const cancelMsg = document.getElementById('cancel-msg');

      if (!phoneRaw) {
        cancelMsg.textContent = 'Bitte gib deine Handynummer ein.';
        cancelMsg.style.color = 'var(--color-error)';
        cancelMsg.style.display = 'block';
        return;
      }

      if (!isValidGermanMobile(phoneRaw)) {
        if (isLandline(phoneRaw)) {
          cancelMsg.textContent = 'FragSMS funktioniert nur mit Mobilfunknummern (015x, 016x, 017x).';
        } else {
          cancelMsg.textContent = 'Bitte gib eine gueltige deutsche Handynummer ein (z.B. 151 2345 6789).';
        }
        cancelMsg.style.color = 'var(--color-error)';
        cancelMsg.style.display = 'block';
        return;
      }

      const phone = normalizePhone(phoneRaw);

      if (!confirm('Bist du sicher, dass du dein Abo kuendigen moechtest?')) return;

      const cancelBtn = document.getElementById('cancel-btn');
      cancelBtn.disabled = true;
      cancelBtn.textContent = 'Wird gekuendigt...';

      try {
        const response = await fetch(`${STRIPE_WORKER_URL}/cancel`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone }),
        });

        const data = await response.json();

        if (data.success) {
          cancelMsg.textContent = data.message;
          cancelMsg.style.color = 'var(--color-success)';
        } else {
          cancelMsg.textContent = data.error || 'Fehler beim Kuendigen.';
          cancelMsg.style.color = 'var(--color-error)';
        }
      } catch (err) {
        cancelMsg.textContent = 'Verbindungsfehler. Bitte versuche es erneut.';
        cancelMsg.style.color = 'var(--color-error)';
      }

      cancelMsg.style.display = 'block';
      cancelBtn.disabled = false;
      cancelBtn.textContent = 'Jetzt kuendigen';
    });

    // --- Cancel addon only ---
    const cancelAddonBtn = document.getElementById('cancel-addon-btn');
    if (cancelAddonBtn) {
      cancelAddonBtn.addEventListener('click', async () => {
        const phoneRaw = document.getElementById('cancel-phone').value.trim();
        const cancelMsg = document.getElementById('cancel-msg');

        if (!phoneRaw) {
          cancelMsg.textContent = 'Bitte gib deine Handynummer ein.';
          cancelMsg.style.color = 'var(--color-error)';
          cancelMsg.style.display = 'block';
          return;
        }

        if (!isValidGermanMobile(phoneRaw)) {
          if (isLandline(phoneRaw)) {
            cancelMsg.textContent = 'FragSMS funktioniert nur mit Mobilfunknummern (015x, 016x, 017x).';
          } else {
            cancelMsg.textContent = 'Bitte gib eine gueltige deutsche Handynummer ein (z.B. 151 2345 6789).';
          }
          cancelMsg.style.color = 'var(--color-error)';
          cancelMsg.style.display = 'block';
          return;
        }

        const phone = normalizePhone(phoneRaw);

        if (!confirm('Web-Suche Add-on kuendigen?')) return;

        cancelAddonBtn.disabled = true;
        cancelAddonBtn.textContent = 'Wird gekuendigt...';

        try {
          const response = await fetch(`${STRIPE_WORKER_URL}/cancel`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone, cancel_type: 'addon' }),
          });

          const data = await response.json();

          if (data.success) {
            cancelMsg.textContent = data.message;
            cancelMsg.style.color = 'var(--color-success)';
          } else {
            cancelMsg.textContent = data.error || 'Fehler beim Kuendigen.';
            cancelMsg.style.color = 'var(--color-error)';
          }
        } catch (err) {
          cancelMsg.textContent = 'Verbindungsfehler. Bitte versuche es erneut.';
          cancelMsg.style.color = 'var(--color-error)';
        }

        cancelMsg.style.display = 'block';
        cancelAddonBtn.disabled = false;
        cancelAddonBtn.textContent = 'Add-on kuendigen';
      });
    }
  </script>

  <!-- Page translations for upgrade -->
  <script>
    window.__fragTranslations = {
      de: {
        upgrade_badge: 'Abo verwalten',
        upgrade_subtitle: 'W\u00e4hle deinen Tarif und zahle sicher mit Karte, SEPA oder Sofort.',
        upgrade_phone_label: 'Deine Handynummer',
        upgrade_phone_hint: 'Die Nummer, mit der du FragSMS per SMS nutzt.',
        upgrade_plan_label: 'Tarif w\u00e4hlen',
        upgrade_starter_msgs: '30 Nachr./Monat',
        upgrade_basic_msgs: '150 Nachr./Monat',
        upgrade_pro_msgs: '500 Nachr./Monat',
        badge_popular: 'Beliebt',
        addon_label: '\uD83D\uDD0D Web-Suche Add-on',
        addon_desc: '200 Web-Suchen/Monat. Aktuelle Infos direkt per SMS.',
        upgrade_cb_widerruf: 'Ich stimme zu, dass FragSMS sofort beginnt und verzichte auf mein 14-t\u00e4giges Widerrufsrecht (\u00a7356 Abs. 5 BGB).',
        upgrade_cb_datenschutz: 'Ich habe die <a href="/datenschutz" target="_blank">Datenschutzerkl\u00e4rung</a> gelesen und stimme zu.',
        upgrade_stripe_note: 'Sichere Zahlung \u00fcber Stripe. Karte, SEPA-Lastschrift oder Sofort\u00fcberweisung.',
        cancel_heading: 'Abo k\u00fcndigen',
        cancel_desc: 'Du hast bereits ein Abo und m\u00f6chtest k\u00fcndigen? Gib deine Handynummer ein.',
        cancel_addon_btn: 'Add-on k\u00fcndigen'
      },
      en: {
        upgrade_badge: 'Manage subscription',
        upgrade_subtitle: 'Choose your plan and pay securely with card, SEPA, or instant transfer.',
        upgrade_phone_label: 'Your phone number',
        upgrade_phone_hint: 'The number you use to text FragSMS.',
        upgrade_plan_label: 'Choose plan',
        upgrade_starter_msgs: '30 msgs/month',
        upgrade_basic_msgs: '150 msgs/month',
        upgrade_pro_msgs: '500 msgs/month',
        badge_popular: 'Popular',
        addon_label: '\uD83D\uDD0D Web Search Add-on',
        addon_desc: '200 web searches/month. Real-time info via SMS.',
        upgrade_cb_widerruf: 'I agree that FragSMS starts immediately and waive my 14-day right of withdrawal (\u00a7356 para. 5 BGB).',
        upgrade_cb_datenschutz: 'I have read and agree to the <a href="/datenschutz" target="_blank">Privacy Policy</a>.',
        upgrade_stripe_note: 'Secure payment via Stripe. Card, SEPA direct debit, or instant transfer.',
        cancel_heading: 'Cancel subscription',
        cancel_desc: 'Already have a subscription and want to cancel? Enter your phone number.',
        cancel_addon_btn: 'Cancel add-on'
      }
    };
    if (window.__fragApplyLang) window.__fragApplyLang();
  </script>
</Base>
