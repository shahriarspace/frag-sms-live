---
import Base from '../layouts/Base.astro';
---

<Base title="Zahlung erfolgreich — FragSMS" noindex={true}>
  <section class="section" style="text-align: center;">
    <div class="container" style="max-width: 500px;">
      <div class="fade-in">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(34, 197, 94, 0.1); border: 2px solid var(--color-success); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.75rem; color: var(--color-success);">
          &#10003;
        </div>
        <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 1rem; color: var(--color-success);">
          Zahlung erfolgreich!
        </h1>
        <p style="font-size: 1.1rem; margin-bottom: 2.5rem; color: var(--color-text-muted);">
          Dein FragSMS Upgrade ist jetzt aktiv. Du erh&auml;ltst in K&uuml;rze eine Best&auml;tigung per SMS.
        </p>
      </div>

      <div class="card fade-in" style="margin-bottom: 2.5rem; text-align: left;">
        <h2 style="font-size: 1rem; margin-bottom: 0.75rem; color: var(--color-text);">So geht's weiter:</h2>
        <p style="font-size: 0.9rem; color: var(--color-text-muted);">
          Sende einfach eine SMS an deine FragSMS-Nummer. Dein erh&ouml;htes Nachrichtenlimit ist sofort verf&uuml;gbar.
        </p>
      </div>

      <a href="/" class="btn-primary">
        Zur&uuml;ck zur Startseite
      </a>
    </div>
  </section>
</Base>
