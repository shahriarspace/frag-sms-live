---
import Base from '../layouts/Base.astro';
---

<Base title="Zahlung erfolgreich — FragSMS" noindex={true}>
  <section style="padding: 4rem 0; text-align: center;">
    <div class="container" style="max-width: 500px;">
      <div style="font-size: 3rem; margin-bottom: 1rem;">&#10003;</div>
      <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-success);">
        Zahlung erfolgreich!
      </h1>
      <p style="font-size: 1.1rem; margin-bottom: 2rem; color: var(--color-text-muted);">
        Dein FragSMS Upgrade ist jetzt aktiv. Du erh&auml;ltst in K&uuml;rze eine Best&auml;tigung per SMS.
      </p>

      <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem;">
        <h2 style="font-size: 1rem; margin-bottom: 0.75rem;">So geht's weiter:</h2>
        <p style="font-size: 0.9rem; color: var(--color-text-muted);">
          Sende einfach eine SMS an deine FragSMS-Nummer. Dein erh&ouml;htes Nachrichtenlimit ist sofort verf&uuml;gbar.
        </p>
      </div>

      <a href="/" style="display: inline-block; background: var(--color-primary); color: white; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;">
        Zur&uuml;ck zur Startseite
      </a>
    </div>
  </section>
</Base>
