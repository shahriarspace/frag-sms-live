---
import { brand } from '../config/brand.js';

export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  legalPage?: boolean;
}

const defaultDesc = brand.country === 'DE'
  ? brand.name + ' \u2014 Dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Frag einfach per SMS und erhalte sofort KI-Antworten. ' + brand.legal.privacyLabel + ', ' + brand.legal.serverLabel + '-Daten.'
  : brand.country === 'BD'
  ? brand.name + ' \u2014 SMS-e AI assistant. App, internet ba login lagbe na. Proshno korle shothik uttor paben.'
  : brand.name + ' \u2014 Your AI assistant via SMS. No app, no internet, no login. Just text and get instant AI answers.';

const defaultKeywords = brand.country === 'DE'
  ? 'KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, SMS KI, AI SMS ohne App, DSGVO KI, ' + brand.name
  : brand.country === 'BD'
  ? 'AI SMS Bangladesh, AI assistant SMS, HelloKobi, SMS AI no internet, AI without app'
  : 'AI via SMS, ChatGPT via SMS, AI assistant USA, SMS AI, AI without app, ' + brand.name;

const {
  title,
  description = defaultDesc,
  keywords = defaultKeywords,
  ogImage = '/og-image.svg',
  noindex = false,
  jsonLd,
  legalPage = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const B = brand;
---

<!doctype html>
<html lang={B.lang.default} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={B.name} />
    <meta name="theme-color" content="#0a0a0a" id="meta-theme-color" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />

    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="alternate" hreflang={B.lang.default} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Preconnect for performance -->
    <link rel="preconnect" href={'https://' + B.urls.stripeDomain} crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={B.schema.ogLocale} />
    <meta property="og:site_name" content={B.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={B.name + ' \u2014 AI assistant via SMS'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={B.name + ' \u2014 AI assistant via SMS'} />

    <!-- Structured Data: Organization (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": B.name,
      "url": B.urls.site,
      "logo": B.urls.site + "/logo.svg",
      "description": "AI assistant via SMS. No app, no internet. " + B.legal.privacyLabel + ".",
      "foundingDate": "2026",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": B.contactEmail,
        "contactType": "customer service",
        "availableLanguage": B.schema.lang
      },
      "areaServed": {
        "@type": "Country",
        "name": B.schema.countryName
      }
    })} />

    <!-- Structured Data: WebSite with SearchAction -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": B.name,
      "url": B.urls.site,
      "inLanguage": B.lang.default,
      "description": B.name + ' \u2014 ' + B.tagline
    })} />

    <!-- Page-specific structured data -->
    {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(data => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- Theme detection: apply before paint to prevent flash -->
    <script is:inline define:vars={{ brandStoragePrefix: B.name.toLowerCase() }}>
      (function(){
        var t = localStorage.getItem(brandStoragePrefix + '-theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
        var m = document.getElementById('meta-theme-color');
        if (m) m.setAttribute('content', t === 'light' ? '#ffffff' : '#0a0a0a');
      })();
    </script>

    <style is:global>
      /* Skip to content link */
      .skip-to-content {
        position: absolute;
        top: -100%;
        left: 50%;
        transform: translateX(-50%);
        background: var(--color-primary);
        color: var(--color-btn-text);
        padding: 0.75rem 1.5rem;
        border-radius: 0 0 8px 8px;
        font-weight: 700;
        font-size: 0.9rem;
        z-index: 200;
        text-decoration: none;
        transition: top 0.2s;
      }
      .skip-to-content:focus {
        top: 0;
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }

      :root {
        /* Dark theme (default) */
        --color-bg: #0a0a0a;
        --color-bg-alt: #111111;
        --color-surface: #161616;
        --color-surface-hover: #1e1e1e;
        --color-text: #f0f0f0;
        --color-text-muted: #888;
        --color-border: #242424;
        --color-border-hover: #333;
        --color-primary: #10b981;
        --color-primary-dark: #059669;
        --color-primary-glow: rgba(16, 185, 129, 0.12);
        --color-primary-border: rgba(16, 185, 129, 0.25);
        --color-success: #22c55e;
        --color-error: #ef4444;
        --color-error-glow: rgba(239, 68, 68, 0.12);
        --color-btn-text: #0a0a0a;
        --color-header-bg: rgba(10, 10, 10, 0.9);
        --color-phone-bg: #1a1a1a;
        --color-phone-border: #333;
        --color-sms-received-bg: #1e1e1e;
        --color-sms-received-border: #2a2a2a;
        --color-dot-bg: #2a2a2a;
        --color-dot-hover: #3a3a3a;
        --color-footer-dim: #666;
        --color-footer-dimmer: #555;
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        --max-width: 1120px;
      }

      /* Light theme */
      [data-theme="light"] {
        --color-bg: #ffffff;
        --color-bg-alt: #f7f7f8;
        --color-surface: #f0f0f2;
        --color-surface-hover: #e8e8ea;
        --color-text: #1a1a1a;
        --color-text-muted: #5a5a5a;
        --color-border: #dcdcdc;
        --color-border-hover: #bbb;
        --color-primary: #059669;
        --color-primary-dark: #047857;
        --color-primary-glow: rgba(5, 150, 105, 0.1);
        --color-primary-border: rgba(5, 150, 105, 0.3);
        --color-success: #16a34a;
        --color-error: #dc2626;
        --color-error-glow: rgba(220, 38, 38, 0.1);
        --color-btn-text: #ffffff;
        --color-header-bg: rgba(255, 255, 255, 0.92);
        --color-phone-bg: #f5f5f5;
        --color-phone-border: #d0d0d0;
        --color-sms-received-bg: #e8e8ea;
        --color-sms-received-border: #d0d0d0;
        --color-dot-bg: #ccc;
        --color-dot-hover: #aaa;
        --color-footer-dim: #888;
        --color-footer-dimmer: #999;
      }

      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      a:hover {
        color: var(--color-primary-dark);
        text-decoration: underline;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 2rem;
      }
      @media (max-width: 400px) {
        .container { padding: 0 1rem; }
      }

      /* Fade-in animation */
      .fade-in {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Emerald gradient text */
      .text-gradient {
        background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      [data-theme="light"] .text-gradient {
        background: linear-gradient(135deg, #047857 0%, #059669 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Button styles */
      .btn-primary {
        display: inline-block;
        background: var(--color-primary);
        color: var(--color-btn-text);
        padding: 0.8rem 2rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .btn-primary:hover {
        background: var(--color-primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 6px 24px rgba(16, 185, 129, 0.3);
        text-decoration: none;
        color: var(--color-btn-text);
      }

      .btn-secondary {
        display: inline-block;
        background: transparent;
        color: var(--color-text);
        padding: 0.8rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid var(--color-border);
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .btn-secondary:hover {
        border-color: var(--color-primary);
        background: var(--color-primary-glow);
        text-decoration: none;
        color: var(--color-text);
      }

      /* Scrollbar styling */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-border);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-border-hover);
      }

      /* Selection color — emerald tint */
      ::selection {
        background: rgba(16, 185, 129, 0.3);
        color: var(--color-text);
      }

      /* Global focus-visible styles for keyboard navigation */
      :focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }
      /* Remove default outline for mouse clicks */
      :focus:not(:focus-visible) {
        outline: none;
      }

      /* Language switcher */
      .lang-switcher {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.2rem;
        font-size: 0.85rem;
      }
      .lang-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.45rem;
        border: none;
        border-radius: 4px;
        background: transparent;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1;
        transition: background 0.2s;
      }
      .lang-btn svg {
        width: 22px;
        height: 16px;
        border-radius: 2px;
        display: block;
      }
      .lang-btn.active {
        background: var(--color-primary-glow);
        box-shadow: 0 0 0 1px var(--color-primary-border);
      }
      .lang-btn:hover:not(.active) {
        background: var(--color-surface-hover);
      }

      /* Theme toggle */
      .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
        cursor: pointer;
        color: var(--color-text-muted);
        transition: background 0.2s, border-color 0.2s, color 0.2s;
        padding: 0;
        flex-shrink: 0;
      }
      .theme-toggle:hover {
        background: var(--color-surface-hover);
        border-color: var(--color-primary);
      }
      /* In dark mode: show sun, hide moon */
      .theme-icon-sun { display: block; }
      .theme-icon-moon { display: none; }
      /* In light mode: show moon, hide sun */
      [data-theme="light"] .theme-icon-sun { display: none; }
      [data-theme="light"] .theme-icon-moon { display: block; }

      /* Smooth theme transition */
      html.theme-transition,
      html.theme-transition *,
      html.theme-transition *::before,
      html.theme-transition *::after {
        transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease !important;
      }

      /* Legal page styles */
      .legal-content {
        max-width: 700px;
        margin: 0 auto;
        font-size: 0.9rem;
        line-height: 1.8;
      }
      .legal-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
      }
      .legal-content h2 {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 2.5rem 0 0.75rem;
        color: var(--color-text);
      }
      .legal-content h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
      }
      .legal-content p {
        color: var(--color-text-muted);
        margin-bottom: 0.75rem;
      }
      .legal-content ul {
        margin: 0.5rem 0 1rem 1.5rem;
        color: var(--color-text-muted);
      }
      .legal-content li {
        padding: 0.2rem 0;
      }
      .legal-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.85rem;
      }
      .legal-content th {
        text-align: left;
        padding: 0.75rem;
        border-bottom: 2px solid var(--color-border);
        color: var(--color-text);
        font-weight: 600;
      }
      .legal-content td {
        padding: 0.75rem;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text-muted);
      }
      .legal-content strong {
        color: var(--color-text);
      }
      .legal-content a {
        color: var(--color-primary);
      }

      /* Hamburger menu button — hidden on desktop */
      .hamburger-btn {
        display: none;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        background: var(--color-surface);
        cursor: pointer;
        padding: 0;
        flex-shrink: 0;
        transition: background 0.2s, border-color 0.2s;
      }
      .hamburger-btn:hover {
        background: var(--color-surface-hover);
        border-color: var(--color-primary);
      }
      .hamburger-bar {
        display: block;
        width: 16px;
        height: 2px;
        background: var(--color-text-muted);
        border-radius: 1px;
        transition: transform 0.3s ease, opacity 0.3s ease;
      }
      .hamburger-inner {
        display: flex;
        flex-direction: column;
        gap: 3px;
        align-items: center;
      }
      /* Hamburger to X animation when open */
      .hamburger-btn.open .hamburger-bar:nth-child(1) {
        transform: translateY(5px) rotate(45deg);
      }
      .hamburger-btn.open .hamburger-bar:nth-child(2) {
        opacity: 0;
      }
      .hamburger-btn.open .hamburger-bar:nth-child(3) {
        transform: translateY(-5px) rotate(-45deg);
      }

      /* Mobile nav dropdown — hidden on desktop */
      .mobile-nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--color-bg);
        border-bottom: 1px solid var(--color-border);
        padding: 1rem 0;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        z-index: 99;
      }
      [data-theme="light"] .mobile-nav {
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      }
      .mobile-nav.open {
        display: block;
      }
      .mobile-nav a {
        display: block;
        padding: 0.75rem 2rem;
        color: var(--color-text-muted);
        font-size: 0.95rem;
        font-weight: 500;
        transition: background 0.2s, color 0.2s;
        text-decoration: none;
      }
      .mobile-nav a:hover {
        background: var(--color-surface);
        color: var(--color-primary);
        text-decoration: none;
      }

      /* Desktop nav links */
      .nav-link-desktop {
        color: var(--color-text-muted);
        transition: color 0.2s;
      }

      /* Responsive: mobile layout */
      @media (max-width: 768px) {
        .nav-link-desktop {
          display: none !important;
        }
        .hamburger-btn {
          display: flex;
        }
        .theme-toggle {
          width: 32px;
          height: 32px;
        }
        .theme-toggle svg {
          width: 16px;
          height: 16px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="skip-to-content" data-i18n="skip_to_content">Zum Inhalt springen</a>

    <!-- Header -->
    <header style="border-bottom: 1px solid var(--color-border); padding: 1.1rem 0; backdrop-filter: blur(12px); background: var(--color-header-bg); position: sticky; top: 0; z-index: 100;">
      <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
        <a href="/" style="display: flex; align-items: center; gap: 0.6rem; text-decoration: none;" aria-label={B.name + ' Startseite'}>
          <!-- Speech bubble icon -->
          <svg width="28" height="28" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="flex-shrink: 0;">
            <rect x="0" y="0" width="32" height="32" rx="6" fill="var(--color-bg)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
            <rect x="6" y="5" width="20" height="14" rx="2" fill="var(--color-primary)"/>
            <polygon points="8,19 14,19 8,25" fill="var(--color-primary)"/>
            <text x="16" y="15" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="var(--color-btn-text)" text-anchor="middle">?</text>
            <circle cx="11" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
            <circle cx="16" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
            <circle cx="21" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
          </svg>
          <span style="font-size: 1.3rem; font-weight: 800; letter-spacing: -0.02em;">
            <span style="color: var(--color-text);">{B.logo.part1}</span><span style="color: var(--color-primary);">{B.logo.part2}</span>
          </span>
        </a>
        <nav aria-label="Hauptnavigation" class="header-nav" style="display: flex; align-items: center; gap: 1.75rem; font-size: 0.9rem;">
          <a href="/upgrade" class="nav-link-desktop" data-i18n="nav_upgrade">Upgrade</a>
          <a href="/blog/" class="nav-link-desktop">Blog</a>
          {B.legal.links.slice(0, 2).map(link => (
            <a href={link.href} class="nav-link-desktop">{link.label[B.lang.default]}</a>
          ))}
          <!-- Theme toggle -->
          <button class="theme-toggle" id="theme-toggle" aria-label="Theme wechseln" title="Dark/Light Mode">
            <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="5" fill="#fbbf24"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" fill="#818cf8"/></svg>
          </button>
          {!legalPage && (
            <div class="lang-switcher" aria-label="Language">
              {B.lang.flags.map((f, i) => (
                <button class={'lang-btn' + (i === 0 ? ' active' : '')} data-lang={f.lang} aria-label={f.ariaLabel} title={f.title} data-flag={f.flag}></button>
              ))}
            </div>
          )}
          <!-- Hamburger button — mobile only -->
          <button class="hamburger-btn" id="hamburger-btn" aria-label={B.lang.default === 'de' ? 'Menu oeffnen' : B.lang.default === 'bn' ? 'Menu khulun' : 'Open menu'} aria-expanded="false">
            <span class="hamburger-inner">
              <span class="hamburger-bar"></span>
              <span class="hamburger-bar"></span>
              <span class="hamburger-bar"></span>
            </span>
          </button>
        </nav>
      </div>
      <!-- Mobile nav dropdown -->
      <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile Navigation">
        <a href="/upgrade" data-i18n="nav_upgrade">Upgrade</a>
        <a href="/blog/">Blog</a>
        {B.legal.links.slice(0, 2).map(link => (
          <a href={link.href}>{link.label[B.lang.default]}</a>
        ))}
      </nav>
    </header>

    <!-- Main content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid var(--color-border); padding: 3rem 0; margin-top: 0; background: var(--color-bg-alt);">
      <div class="container" style="text-align: center; font-size: 0.85rem; color: var(--color-text-muted);">
        <!-- Footer logo -->
        <a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; text-decoration: none;" aria-label={B.name}>
          <svg width="22" height="22" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="0" y="0" width="32" height="32" rx="6" fill="var(--color-bg)" stroke="rgba(16,185,129,0.3)" stroke-width="1"/>
            <rect x="6" y="5" width="20" height="14" rx="2" fill="var(--color-primary)"/>
            <polygon points="8,19 14,19 8,25" fill="var(--color-primary)"/>
            <text x="16" y="15" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="var(--color-btn-text)" text-anchor="middle">?</text>
            <circle cx="11" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
            <circle cx="16" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
            <circle cx="21" cy="28" r="1.5" fill="var(--color-primary-dark)"/>
          </svg>
          <span style="font-size: 1rem; font-weight: 800; letter-spacing: -0.02em;">
            <span style="color: var(--color-text);">{B.logo.part1}</span><span style="color: var(--color-primary);">{B.logo.part2}</span>
          </span>
        </a>
        <nav aria-label="Footer-Navigation" style="display: flex; justify-content: center; gap: 1.75rem; margin-bottom: 1.25rem; flex-wrap: wrap;">
          <a href="/upgrade" style="color: var(--color-text-muted);" data-i18n="nav_upgrade">Upgrade</a>
          <a href="/blog/" style="color: var(--color-text-muted);">Blog</a>
          {B.legal.links.map(link => (
            <a href={link.href} style="color: var(--color-text-muted);">{link.label[B.lang.default]}</a>
          ))}
        </nav>
        <p style="color: var(--color-footer-dim);">&copy; {new Date().getFullYear()} {B.name}. <span data-i18n="footer_rights">Alle Rechte vorbehalten.</span></p>
        <p style="margin-top: 0.25rem; color: var(--color-footer-dimmer);" data-i18n="footer_tax">{B.legal.footerTax[B.lang.default]}</p>
      </div>
    </footer>

    <!-- Fade-in observer -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      // Staggered slide-in observer for flow diagrams — sequential reveal
      var flowObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('flow-visible');
            flowObserver.unobserve(entry.target);

            // After first diagram finishes (9 children x 100ms + 500ms anim),
            // chain: checklist -> comparison heading -> comparison diagram
            if (entry.target.classList.contains('flow-diagram')) {
              var section = entry.target.closest('.flow-section');
              if (section) {
                var checklist = section.querySelector('.flow-checklist');
                var cmpHeading = section.querySelector('.flow-heading--compare');
                var cmpDiagram = section.querySelector('.flow-compare');
                if (checklist) {
                  setTimeout(function() { checklist.classList.add('visible'); }, 900);
                }
                if (cmpHeading) {
                  setTimeout(function() { cmpHeading.classList.add('visible'); }, 1200);
                }
                if (cmpDiagram) {
                  setTimeout(function() { cmpDiagram.classList.add('flow-visible'); }, 1500);
                }
              }
            }
          }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.flow-diagram').forEach(function(el) { flowObserver.observe(el); });
    </script>

    <!-- Language switcher logic -->
    <script define:vars={{ brandConfig: { name: B.name, defaultLang: B.lang.default, supported: B.lang.supported, flags: B.lang.flags, legalLinks: B.legal.links, footerTax: B.legal.footerTax } }}>
      (function() {
        var LANG_KEY = brandConfig.name.toLowerCase() + '-lang';
        var defaultLang = brandConfig.defaultLang;

        // Flag SVG definitions — keyed by country code
        var FLAG_SVGS = {
          de: '<svg viewBox="0 0 5 3" xmlns="http://www.w3.org/2000/svg"><rect width="5" height="1" y="0" fill="#000"/><rect width="5" height="1" y="1" fill="#DD0000"/><rect width="5" height="1" y="2" fill="#FFCE00"/></svg>',
          gb: '<svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg"><clipPath id="s"><path d="M0,0 v30 h60 v-30 z"/></clipPath><clipPath id="t"><path d="M30,15 h30 v15 z v15 h-30 z h-30 v-15 z v-15 h30 z"/></clipPath><g clip-path="url(#s)"><path d="M0,0 v30 h60 v-30 z" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#t)" stroke="#C8102E" stroke-width="4"/><path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/><path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/></g></svg>',
          bd: '<svg viewBox="0 0 5 3" xmlns="http://www.w3.org/2000/svg"><rect width="5" height="3" fill="#006a4e"/><circle cx="2.25" cy="1.5" r="0.9" fill="#f42a41"/></svg>',
          us: '<svg viewBox="0 0 190 100" xmlns="http://www.w3.org/2000/svg"><rect width="190" height="100" fill="#B22234"/><g fill="#fff"><rect y="7.69" width="190" height="7.69"/><rect y="23.08" width="190" height="7.69"/><rect y="38.46" width="190" height="7.69"/><rect y="53.85" width="190" height="7.69"/><rect y="69.23" width="190" height="7.69"/><rect y="84.62" width="190" height="7.69"/></g><rect width="76" height="53.85" fill="#3C3B6E"/></svg>',
          es: '<svg viewBox="0 0 5 3" xmlns="http://www.w3.org/2000/svg"><rect width="5" height="0.75" fill="#AA151B"/><rect width="5" height="1.5" y="0.75" fill="#F1BF00"/><rect width="5" height="0.75" y="2.25" fill="#AA151B"/></svg>'
        };

        // Inject flag SVGs into lang buttons
        document.querySelectorAll('.lang-btn[data-flag]').forEach(function(btn) {
          var flag = btn.getAttribute('data-flag');
          if (FLAG_SVGS[flag]) btn.innerHTML = FLAG_SVGS[flag];
        });

        // Shared translations for header/footer
        var baseTranslations = {
          de: {
            nav_upgrade: 'Upgrade',
            footer_rights: 'Alle Rechte vorbehalten.',
            footer_tax: brandConfig.footerTax.de || '',
            skip_to_content: 'Zum Inhalt springen'
          },
          en: {
            nav_upgrade: 'Upgrade',
            footer_rights: 'All rights reserved.',
            footer_tax: brandConfig.footerTax.en || '',
            skip_to_content: 'Skip to content'
          },
          bn: {
            nav_upgrade: 'Upgrade',
            footer_rights: '\u09b8\u09b0\u09cd\u09ac\u09b8\u09cd\u09ac\u09a4\u09cd\u09ac \u09b8\u0982\u09b0\u0995\u09cd\u09b7\u09bf\u09a4\u0964',
            footer_tax: brandConfig.footerTax.bn || '',
            skip_to_content: '\u0995\u09a8\u09cd\u099f\u09c7\u09a8\u09cd\u099f\u09c7 \u09af\u09be\u09a8'
          },
          es: {
            nav_upgrade: 'Upgrade',
            footer_rights: 'Todos los derechos reservados.',
            footer_tax: brandConfig.footerTax.es || '',
            skip_to_content: 'Ir al contenido'
          }
        };

        function getStoredLang() {
          try { return localStorage.getItem(LANG_KEY) || defaultLang; } catch(e) { return defaultLang; }
        }

        function setStoredLang(lang) {
          try { localStorage.setItem(LANG_KEY, lang); } catch(e) {}
        }

        function applyLang(lang) {
          // Merge base translations with any page-level translations
          var pageTranslations = window.__fragTranslations || {};
          var base = baseTranslations[lang] || baseTranslations.en || {};
          var page = pageTranslations[lang] || {};
          var strings = Object.assign({}, base, page);

          // Update all data-i18n elements
          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            if (strings[key] !== undefined) {
              el.innerHTML = strings[key];
            }
          });

          // Update data-i18n-placeholder elements
          document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-placeholder');
            if (strings[key] !== undefined) {
              el.placeholder = strings[key];
            }
          });

          // Update lang-btn active state
          document.querySelectorAll('.lang-btn').forEach(function(btn) {
            btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
          });

          // Update html lang attribute
          document.documentElement.lang = lang;
        }

        // Initialize on load
        var currentLang = getStoredLang();
        // Apply on DOMContentLoaded to ensure page translations are registered
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { applyLang(currentLang); });
        } else {
          applyLang(currentLang);
        }

        // Bind click events
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var lang = btn.getAttribute('data-lang');
            setStoredLang(lang);
            currentLang = lang;
            applyLang(lang);
          });
        });

        // Expose for pages to trigger re-apply after registering translations
        window.__fragApplyLang = function() { applyLang(getStoredLang()); };
        window.__fragGetLang = getStoredLang;
      })();
    </script>

    <!-- Theme toggle logic -->
    <script is:inline define:vars={{ themeStorageKey: B.name.toLowerCase() + '-theme' }}>
      (function() {
        var THEME_KEY = themeStorageKey;

        function getEffectiveTheme() {
          var stored = null;
          try { stored = localStorage.getItem(THEME_KEY); } catch(e) {}
          if (stored === 'light' || stored === 'dark') return stored;
          return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }

        function applyTheme(theme) {
          document.documentElement.classList.add('theme-transition');
          document.documentElement.setAttribute('data-theme', theme);
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'light' ? '#ffffff' : '#0a0a0a');
          setTimeout(function() {
            document.documentElement.classList.remove('theme-transition');
          }, 350);
        }

        var btn = document.getElementById('theme-toggle');
        if (btn) {
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme') || getEffectiveTheme();
            var next = current === 'dark' ? 'light' : 'dark';
            try { localStorage.setItem(THEME_KEY, next); } catch(e) {}
            applyTheme(next);
          });
        }

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          var stored = null;
          try { stored = localStorage.getItem(THEME_KEY); } catch(ex) {}
          if (!stored) {
            applyTheme(e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>

    <!-- Hamburger menu logic -->
    <script is:inline define:vars={{ menuLabels: { open: B.lang.default === 'de' ? 'Menu oeffnen' : B.lang.default === 'bn' ? 'Menu khulun' : 'Open menu', close: B.lang.default === 'de' ? 'Menu schliessen' : B.lang.default === 'bn' ? 'Menu bondho korun' : 'Close menu' } }}>
      (function() {
        var hamburgerBtn = document.getElementById('hamburger-btn');
        var mobileNav = document.getElementById('mobile-nav');
        if (!hamburgerBtn || !mobileNav) return;

        hamburgerBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          var isOpen = mobileNav.classList.contains('open');
          mobileNav.classList.toggle('open');
          hamburgerBtn.classList.toggle('open');
          hamburgerBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
          hamburgerBtn.setAttribute('aria-label', isOpen ? menuLabels.open : menuLabels.close);
        });

        mobileNav.querySelectorAll('a').forEach(function(link) {
          link.addEventListener('click', function() {
            mobileNav.classList.remove('open');
            hamburgerBtn.classList.remove('open');
            hamburgerBtn.setAttribute('aria-expanded', 'false');
            hamburgerBtn.setAttribute('aria-label', menuLabels.open);
          });
        });

        document.addEventListener('click', function(e) {
          if (!mobileNav.contains(e.target) && !hamburgerBtn.contains(e.target)) {
            mobileNav.classList.remove('open');
            hamburgerBtn.classList.remove('open');
            hamburgerBtn.setAttribute('aria-expanded', 'false');
            hamburgerBtn.setAttribute('aria-label', menuLabels.open);
          }
        });
      })();
    </script>
  </body>
</html>
