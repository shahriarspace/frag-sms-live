---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object | object[];
  legalPage?: boolean;
}

const {
  title,
  description = 'FragSMS — Dein KI-Assistent per SMS in Deutschland. Kein App, kein Internet, kein Login. Frag einfach per SMS und erhalte sofort KI-Antworten. DSGVO-konform, EU-Daten.',
  keywords = 'KI per SMS, ChatGPT per SMS, KI Assistent Deutschland, SMS KI, AI SMS ohne App, DSGVO KI, FragSMS',
  ogImage = '/frag-sms-live/og-image.png',
  noindex = false,
  jsonLd,
  legalPage = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="FragSMS" />
    <meta name="theme-color" content="#0a0a0a" />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/frag-sms-live/sitemap.xml" />
    <link rel="alternate" hreflang="de" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://stripe.fragsms.de" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="FragSMS" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="FragSMS — KI-Assistent per SMS in Deutschland" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="FragSMS — KI-Assistent per SMS in Deutschland" />

    <!-- Structured Data: Organization (all pages) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "FragSMS",
      "url": "https://fragsms.de",
      "logo": "https://fragsms.de/logo.png",
      "description": "KI-Assistent per SMS in Deutschland. Kein App, kein Internet. DSGVO-konform.",
      "foundingDate": "2026",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "kontakt@fragsms.de",
        "contactType": "customer service",
        "availableLanguage": "German"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Germany"
      }
    })} />

    <!-- Structured Data: WebSite with SearchAction -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "FragSMS",
      "url": "https://fragsms.de",
      "inLanguage": "de",
      "description": "KI-Assistent per SMS — Frag einfach."
    })} />

    <!-- Page-specific structured data -->
    {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(data => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <style is:global>
      :root {
        /* Emerald dark theme (Kobi-inspired) */
        --color-bg: #0a0a0a;
        --color-bg-alt: #111111;
        --color-surface: #1a1a1a;
        --color-surface-hover: #222222;
        --color-text: #f5f5f5;
        --color-text-muted: #a3a3a3;
        --color-border: #2a2a2a;
        --color-border-hover: #3a3a3a;
        --color-primary: #10b981;
        --color-primary-dark: #059669;
        --color-primary-glow: rgba(16, 185, 129, 0.15);
        --color-primary-border: rgba(16, 185, 129, 0.3);
        --color-success: #22c55e;
        --color-error: #ef4444;
        --color-error-glow: rgba(239, 68, 68, 0.15);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        --max-width: 1100px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-sans);
        color: var(--color-text);
        background: var(--color-bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      a:hover {
        color: var(--color-primary-dark);
        text-decoration: underline;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* Fade-in animation */
      .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Emerald gradient text */
      .text-gradient {
        background: linear-gradient(135deg, #10b981, #34d399);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Card base style */
      .card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 2rem;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
      }
      .card:hover {
        border-color: var(--color-border-hover);
        box-shadow: 0 0 30px rgba(16, 185, 129, 0.06);
      }

      /* Badge styles */
      .badge {
        display: inline-block;
        padding: 0.3rem 0.85rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.025em;
      }
      .badge-primary {
        background: var(--color-primary-glow);
        color: var(--color-primary);
        border: 1px solid var(--color-primary-border);
      }
      .badge-muted {
        background: rgba(163, 163, 163, 0.1);
        color: var(--color-text-muted);
        border: 1px solid rgba(163, 163, 163, 0.15);
      }

      /* Button styles */
      .btn-primary {
        display: inline-block;
        background: var(--color-primary);
        color: #0a0a0a;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        border: none;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
        text-decoration: none;
      }
      .btn-primary:hover {
        background: var(--color-primary-dark);
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
        text-decoration: none;
        color: #0a0a0a;
      }

      .btn-secondary {
        display: inline-block;
        background: var(--color-surface);
        color: var(--color-text);
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid var(--color-border);
        cursor: pointer;
        transition: border-color 0.2s ease, background 0.2s ease;
        text-decoration: none;
      }
      .btn-secondary:hover {
        border-color: var(--color-primary);
        background: var(--color-surface-hover);
        text-decoration: none;
        color: var(--color-text);
      }

      /* Section spacing */
      .section {
        padding: 5rem 0;
      }

      /* Section heading */
      .section-heading {
        text-align: center;
        margin-bottom: 3rem;
      }
      .section-heading h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
      }
      .section-heading p {
        color: var(--color-text-muted);
        font-size: 1rem;
        max-width: 500px;
        margin: 0 auto;
      }

      /* German flag tricolor divider */
      .tricolor-divider {
        display: flex;
        height: 3px;
      }
      .tricolor-divider > div:first-child {
        flex: 1;
        background: #000000;
      }
      .tricolor-divider > div:nth-child(2) {
        flex: 1;
        background: #DD0000;
      }
      .tricolor-divider > div:last-child {
        flex: 1;
        background: #FFD700;
      }

      /* Scrollbar styling */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-border);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-border-hover);
      }

      /* Selection color — emerald tint */
      ::selection {
        background: rgba(16, 185, 129, 0.3);
        color: var(--color-text);
      }

      /* Language switcher */
      .lang-switcher {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.2rem;
        font-size: 0.85rem;
      }
      .lang-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.3rem 0.45rem;
        border: none;
        border-radius: 4px;
        background: transparent;
        cursor: pointer;
        font-size: 0.9rem;
        line-height: 1;
        transition: background 0.2s;
      }
      .lang-btn svg {
        width: 22px;
        height: 16px;
        border-radius: 2px;
        display: block;
      }
      .lang-btn.active {
        background: var(--color-primary-glow);
        box-shadow: 0 0 0 1px var(--color-primary-border);
      }
      .lang-btn:hover:not(.active) {
        background: var(--color-surface-hover);
      }

      /* Legal page styles */
      .legal-content {
        max-width: 700px;
        margin: 0 auto;
        font-size: 0.9rem;
        line-height: 1.8;
      }
      .legal-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
      }
      .legal-content h2 {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 2.5rem 0 0.75rem;
        color: var(--color-text);
      }
      .legal-content h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
      }
      .legal-content p {
        color: var(--color-text-muted);
        margin-bottom: 0.75rem;
      }
      .legal-content ul {
        margin: 0.5rem 0 1rem 1.5rem;
        color: var(--color-text-muted);
      }
      .legal-content li {
        padding: 0.2rem 0;
      }
      .legal-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.85rem;
      }
      .legal-content th {
        text-align: left;
        padding: 0.75rem;
        border-bottom: 2px solid var(--color-border);
        color: var(--color-text);
        font-weight: 600;
      }
      .legal-content td {
        padding: 0.75rem;
        border-bottom: 1px solid var(--color-border);
        color: var(--color-text-muted);
      }
      .legal-content strong {
        color: var(--color-text);
      }
      .legal-content a {
        color: var(--color-primary);
      }

      /* Responsive header nav */
      @media (max-width: 600px) {
        .header-nav {
          gap: 1rem !important;
          font-size: 0.8rem !important;
        }
      }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header style="border-bottom: 1px solid var(--color-border); padding: 1rem 0; backdrop-filter: blur(8px); background: rgba(10, 10, 10, 0.85); position: sticky; top: 0; z-index: 100;">
      <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
        <a href="/frag-sms-live/" style="font-size: 1.3rem; font-weight: 800; letter-spacing: -0.02em;" aria-label="FragSMS Startseite">
          <span style="color: var(--color-text);">Frag</span><span style="color: var(--color-primary);">SMS</span>
        </a>
        <nav aria-label="Hauptnavigation" class="header-nav" style="display: flex; align-items: center; gap: 1.75rem; font-size: 0.9rem;">
          <a href="/frag-sms-live/upgrade" style="color: var(--color-text-muted); transition: color 0.2s;" data-i18n="nav_upgrade">Upgrade</a>
          <a href="/frag-sms-live/impressum" style="color: var(--color-text-muted); transition: color 0.2s;">Impressum</a>
          <a href="/frag-sms-live/datenschutz" style="color: var(--color-text-muted); transition: color 0.2s;" data-i18n="nav_datenschutz">Datenschutz</a>
          {!legalPage && (
            <div class="lang-switcher" aria-label="Sprache / Language">
              <button class="lang-btn active" data-lang="de" aria-label="Deutsch" title="Deutsch"><svg viewBox="0 0 5 3" xmlns="http://www.w3.org/2000/svg"><rect width="5" height="1" y="0" fill="#000"/><rect width="5" height="1" y="1" fill="#DD0000"/><rect width="5" height="1" y="2" fill="#FFCE00"/></svg></button>
              <button class="lang-btn" data-lang="en" aria-label="English" title="English"><svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg"><clipPath id="s"><path d="M0,0 v30 h60 v-30 z"/></clipPath><clipPath id="t"><path d="M30,15 h30 v15 z v15 h-30 z h-30 v-15 z v-15 h30 z"/></clipPath><g clip-path="url(#s)"><path d="M0,0 v30 h60 v-30 z" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#t)" stroke="#C8102E" stroke-width="4"/><path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/><path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/></g></svg></button>
            </div>
          )}
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top: 1px solid var(--color-border); padding: 3rem 0; margin-top: 0; background: var(--color-bg-alt);">
      <div class="container" style="text-align: center; font-size: 0.85rem; color: var(--color-text-muted);">
        <nav aria-label="Footer-Navigation" style="display: flex; justify-content: center; gap: 1.75rem; margin-bottom: 1.25rem;">
          <a href="/frag-sms-live/impressum" style="color: var(--color-text-muted);">Impressum</a>
          <a href="/frag-sms-live/datenschutz" style="color: var(--color-text-muted);" data-i18n="nav_datenschutz">Datenschutz</a>
          <a href="/frag-sms-live/nutzungsbedingungen" style="color: var(--color-text-muted);" data-i18n="footer_nutzungsbedingungen">Nutzungsbedingungen</a>
        </nav>
        <p style="color: #666;">&copy; {new Date().getFullYear()} FragSMS. <span data-i18n="footer_rights">Alle Rechte vorbehalten.</span></p>
        <p style="margin-top: 0.25rem; color: #555;" data-i18n="footer_tax">Gem&auml;&szlig; &sect; 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.</p>
      </div>
    </footer>

    <!-- Fade-in observer -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>

    <!-- Language switcher logic -->
    <script>
      (function() {
        var LANG_KEY = 'fragsms-lang';

        // Shared translations for header/footer (page-specific translations are in each page's script)
        var baseTranslations = {
          de: {
            nav_upgrade: 'Upgrade',
            nav_datenschutz: 'Datenschutz',
            footer_nutzungsbedingungen: 'Nutzungsbedingungen',
            footer_rights: 'Alle Rechte vorbehalten.',
            footer_tax: 'Gem\u00e4\u00df \u00a7 19 Abs. 1 UStG wird keine Umsatzsteuer berechnet.'
          },
          en: {
            nav_upgrade: 'Upgrade',
            nav_datenschutz: 'Privacy Policy',
            footer_nutzungsbedingungen: 'Terms of Service',
            footer_rights: 'All rights reserved.',
            footer_tax: 'As per \u00a7 19 para. 1 UStG, no VAT is charged (small business regulation).'
          }
        };

        function getStoredLang() {
          try { return localStorage.getItem(LANG_KEY) || 'de'; } catch(e) { return 'de'; }
        }

        function setStoredLang(lang) {
          try { localStorage.setItem(LANG_KEY, lang); } catch(e) {}
        }

        function applyLang(lang) {
          // Merge base translations with any page-level translations
          var pageTranslations = window.__fragTranslations || {};
          var deStrings = Object.assign({}, baseTranslations.de, (pageTranslations.de || {}));
          var enStrings = Object.assign({}, baseTranslations.en, (pageTranslations.en || {}));
          var strings = lang === 'en' ? enStrings : deStrings;

          // Update all data-i18n elements
          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            if (strings[key] !== undefined) {
              el.innerHTML = strings[key];
            }
          });

          // Update data-i18n-placeholder elements
          document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-placeholder');
            if (strings[key] !== undefined) {
              el.placeholder = strings[key];
            }
          });

          // Update lang-btn active state
          document.querySelectorAll('.lang-btn').forEach(function(btn) {
            btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
          });

          // Update html lang attribute
          document.documentElement.lang = lang === 'en' ? 'en' : 'de';
        }

        // Initialize on load
        var currentLang = getStoredLang();
        // Apply on DOMContentLoaded to ensure page translations are registered
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { applyLang(currentLang); });
        } else {
          applyLang(currentLang);
        }

        // Bind click events
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var lang = btn.getAttribute('data-lang');
            setStoredLang(lang);
            currentLang = lang;
            applyLang(lang);
          });
        });

        // Expose for pages to trigger re-apply after registering translations
        window.__fragApplyLang = function() { applyLang(getStoredLang()); };
        window.__fragGetLang = getStoredLang;
      })();
    </script>
  </body>
</html>
